@* Style scope for the embedded Keyward UI. Wrap a Keyward page's content in <KeywardUi>...</KeywardUi>;
   the styling lives in KeywardUi.razor.css and — because it is component-scoped CSS in this RCL — is
   bundled automatically into the host app's {Assembly}.styles.css. A host therefore needs NO extra <link>:
   referencing the standard Blazor styles bundle is enough. Override the look via the --kw-* CSS variables.
   Fill: the page header/search stay put and the workspace panes scroll internally (vault pages) — the host
   opts its scroll container in via CSS (see the .kw-fill rules in the reference shell's app.css). *@
<div class="keyward-ui @(Fill ? "kw-fill" : "")">@ChildContent</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Fills the host's content area: header + search stay fixed, tree/content scroll internally.</summary>
    [Parameter] public bool Fill { get; set; }
}
