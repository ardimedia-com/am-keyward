@namespace Am.Keyward.Ui.Blazor.Software
@inject ISoftwareSecretService SecretService
@inject IStringLocalizer<SharedResource> Loc
@inject IJSRuntime JS

@* Application data («Applikations-Daten») for ONE application, rendered inside the Applications page's
   «Daten» tab. Two-pane master-detail (like the vault «Einträge» tab): the secret keys on the left, the
   selected key's per-environment values on the right, with «+ Schlüssel hinzufügen» at the pane's top right.
   A secret key holds ONE value per environment (server-side encrypted, versioned). Reloads when ProjectId
   changes (OnParametersSetAsync). *@
@if (secrets is null)
{
    <p class="muted">@Loc["Common.Loading"]</p>
}
else
{
    <div class="kw-detail-split">
        <div class="kw-split-list">
            <div class="card list-card">
                <div class="list-head">
                    <h3 style="margin:0;">@Loc["App.Data.KeysTitle"]</h3>
                    @if (secrets.Count > 8)
                    {
                        <input @bind="filter" @bind:event="oninput" placeholder="@(Loc["Secret.Filter"])" aria-label="@(Loc["Secret.Filter"])" style="max-width:18rem; margin:.5rem 0 0;" />
                    }
                </div>
                @if (secrets.Count == 0)
                {
                    <div class="empty-state">
                        <KeywardIcon Name="key" Size="28" />
                        <p>@Loc["Secret.Empty"]</p>
                    </div>
                }
                else
                {
                    <div class="list-rows">
                        @foreach (var s in Filtered)
                        {
                            <button class="list-row @(s.Key == selectedKey && mode == "view" ? "selected" : "")" @onclick="() => SelectAsync(s.Key)" disabled="@busy">
                                <KeywardIcon Name="key" Size="17" />
                                <span class="list-row-name">@s.Key</span>
                                <span class="list-row-meta">
                                    <span class="badge">@Loc["Secret.EnvCount", s.EnvironmentsWithValue.Count]</span>
                                    <KeywardIcon Name="chevron-right" Size="15" />
                                </span>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="kw-split-detail">
            @if (mode == "add")
            {
                <div class="card">
                    <h3 style="margin-top:0;">@Loc["Secret.Add"]</h3>
                    <p class="muted">@Loc["Secret.Desc"]</p>
                    <div class="detail-grid" style="max-width:44rem;">
                        <div class="field"><label for="kw-secret-key">@Loc["Secret.Key"]</label><input id="kw-secret-key" @bind="addKey" placeholder="ConnectionStrings:Main" /></div>
                        <div class="field">
                            <label for="kw-secret-env">@Loc["Common.Environment"]</label>
                            <select id="kw-secret-env" @bind="addEnv">
                                @foreach (var e in environmentNames)
                                {
                                    <option value="@e">@e</option>
                                }
                            </select>
                        </div>
                        <div class="field wide"><label for="kw-secret-value">@Loc["Secret.Value"]</label><input id="kw-secret-value" @bind="addValue" autocomplete="off" /></div>
                        <div class="row wide">
                            <button @onclick="SaveNewAsync" disabled="@(busy || string.IsNullOrWhiteSpace(addKey))">@Loc["Common.Save"]</button>
                            <button class="btn-ghost" @onclick="CancelAdd">@Loc["Common.Cancel"]</button>
                        </div>
                    </div>
                    @if (addStatus is not null)
                    {
                        <div class="notice @(addStatus.Value.IsError ? "notice-error" : "")" role="@(addStatus.Value.IsError ? "alert" : "status")">@addStatus.Value.Text</div>
                    }
                </div>
            }
            else if (detail is not null)
            {
                <div class="card">
                    <div class="row" style="justify-content:space-between;">
                        <h3 style="margin:0; display:flex; align-items:center; gap:.5rem;"><KeywardIcon Name="key" Size="18" /><code>@detail.Key</code></h3>
                        <div class="row">
                            <button class="btn-sm" @onclick="StartAdd" disabled="@busy"><KeywardIcon Name="plus" />@Loc["Secret.Add"]</button>
                            <button class="btn-ghost btn-sm" @onclick="() => reveal = !reveal"><KeywardIcon Name="@(reveal ? "eye-off" : "eye")" Size="14" /> @(reveal ? Loc["Secret.HideValues"] : Loc["Secret.RevealValues"])</button>
                            <button class="btn-danger btn-sm" @onclick="() => confirmDelete = true" disabled="@busy">@Loc["Common.DeleteEllipsis"]</button>
                        </div>
                    </div>
                    @if (confirmDelete)
                    {
                        <div class="notice notice-error" style="margin-top:.5rem;">
                            @Loc["Secret.ConfirmDelete", detail.Key]
                            <button class="btn-danger btn-sm" style="margin-left:.5rem;" @onclick="DeleteCurrentAsync" disabled="@busy">@Loc["Common.Yes"]</button>
                            <button class="btn-ghost btn-sm" @onclick="() => confirmDelete = false">@Loc["Common.Cancel"]</button>
                        </div>
                    }
                    <p class="muted">@Loc["Secret.View.Desc"]</p>
                    <div class="table-scroll">
                        <table style="table-layout:fixed; width:100%;">
                            <thead>
                                <tr>
                                    <th style="width:11rem;">@Loc["Common.Environment"]</th>
                                    <th style="width:50%;">@Loc["Secret.CurrentValue"]</th>
                                    <th style="width:50%;">@Loc["Secret.SetNewValue"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var env in detail.Environments)
                                {
                                    var shown = reveal || revealedEnvironments.Contains(env.Environment);
                                    <tr>
                                        <td>@env.Environment</td>
                                        <td>
                                            <div class="row" style="flex-wrap:nowrap;">
                                                <code style="flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis;">@(env.HasValue ? (shown ? env.Value : "••••••••") : "—")</code>
                                                @if (env.HasValue)
                                                {
                                                    <button class="icon-btn" title="@(shown ? Loc["Common.Hide"] : Loc["Common.Reveal"])" @onclick="() => ToggleRowReveal(env.Environment)"><KeywardIcon Name="@(shown ? "eye-off" : "eye")" Size="15" /></button>
                                                    <button class="icon-btn" title="@Loc["Common.Copy"]" @onclick="() => CopyAsync(env.Environment, env.Value)"><KeywardIcon Name="@(copiedEnv == env.Environment ? "check" : "copy")" Size="15" /></button>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <div class="row" style="flex-wrap:nowrap;">
                                                <input @bind="editValues[env.Environment]" placeholder="@(Loc["Secret.NewValuePlaceholder"])" aria-label="@(Loc["Secret.SetNewValue"])" autocomplete="off" style="flex:1; min-width:0;" />
                                                <button class="btn-sm" @onclick="() => SetValueAsync(env.Environment)" disabled="@(busy || string.IsNullOrEmpty(editValues[env.Environment]))">@Loc["Common.Save"]</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="row" style="justify-content:flex-end;">
                        <button class="btn-sm" @onclick="StartAdd" disabled="@busy"><KeywardIcon Name="plus" />@Loc["Secret.Add"]</button>
                    </div>
                    <div class="empty-state">
                        <KeywardIcon Name="key" Size="28" />
                        <p>@(secrets.Count == 0 ? Loc["Secret.Empty"] : Loc["Secret.SelectHint"])</p>
                    </div>
                </div>
            }

            @if (status is not null)
            {
                <div class="notice @(status.Value.IsError ? "notice-error" : "")" role="@(status.Value.IsError ? "alert" : "status")">@status.Value.Text</div>
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public Guid TenantId { get; set; }
    [Parameter, EditorRequired] public Guid ProjectId { get; set; }
    [Parameter] public Guid? ActorUserId { get; set; }

    private Guid loadedProjectId;

    private IReadOnlyList<SoftwareSecretSummary>? secrets;
    private string? selectedKey;
    private SoftwareSecretDetail? detail;
    private string mode = "view"; // "view" | "add"
    private bool reveal;
    private readonly HashSet<string> revealedEnvironments = [];
    private string? copiedEnv;
    private bool confirmDelete;
    private string filter = "";

    private IReadOnlyList<string> environmentNames = [];
    private string addKey = "";
    private string addEnv = "Development";
    private string addValue = "";

    private readonly Dictionary<string, string> editValues = new();

    private (string Text, bool IsError)? status;
    private (string Text, bool IsError)? addStatus;
    private bool busy;

    private IEnumerable<SoftwareSecretSummary> Filtered =>
        secrets is null ? []
        : string.IsNullOrWhiteSpace(filter) ? secrets
        : secrets.Where(s => s.Key.Contains(filter.Trim(), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnParametersSetAsync()
    {
        if (ProjectId != loadedProjectId)
        {
            loadedProjectId = ProjectId;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        selectedKey = null;
        detail = null;
        mode = "view";
        filter = "";
        confirmDelete = false;
        environmentNames = (await SecretService.ListEnvironmentsAsync(TenantId, ProjectId)).Select(e => e.Name).ToList();
        if (!environmentNames.Contains(addEnv))
        {
            addEnv = environmentNames.FirstOrDefault() ?? addEnv;
        }
        await ReloadAsync();
        if (secrets is { Count: 1 })
        {
            await LoadDetailAsync(secrets[0].Key);
        }
    }

    private async Task ReloadAsync() =>
        secrets = await SecretService.ListSecretsAsync(TenantId, ProjectId);

    private Task SelectAsync(string key) => RunAsync(() => LoadDetailAsync(key), true);

    private async Task LoadDetailAsync(string key)
    {
        selectedKey = key;
        mode = "view";
        detail = await SecretService.GetSecretAsync(TenantId, ProjectId, key);
        reveal = false;
        revealedEnvironments.Clear();
        copiedEnv = null;
        confirmDelete = false;
        editValues.Clear();
        if (detail is not null)
        {
            foreach (var e in detail.Environments)
            {
                editValues[e.Environment] = "";
            }
        }
    }

    private void StartAdd()
    {
        mode = "add";
        detail = null;
        selectedKey = null;
        addKey = "";
        addValue = "";
        addStatus = null;
    }

    private void CancelAdd()
    {
        mode = "view";
        addStatus = null;
    }

    private void ToggleRowReveal(string environment)
    {
        if (!revealedEnvironments.Add(environment))
        {
            revealedEnvironments.Remove(environment);
        }
    }

    private async Task CopyAsync(string environment, string value)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
        copiedEnv = environment;
        StateHasChanged();
        await Task.Delay(1200);
        copiedEnv = null;
    }

    private Task SetValueAsync(string environment) => RunAsync(async () =>
    {
        var key = detail!.Key;
        await SecretService.StoreAsync(new StoreSoftwareSecretCommand(TenantId, ProjectId, environment, key, editValues[environment], ActorUserId));
        await LoadDetailAsync(key);
        await ReloadAsync();
        status = (Loc["Secret.Msg.Saved", key, environment], false);
    }, detail is not null && !string.IsNullOrEmpty(editValues.GetValueOrDefault(environment)));

    private Task SaveNewAsync() => RunAsync(async () =>
    {
        var key = addKey.Trim();
        if (secrets?.Any(s => s.Key.Equals(key, StringComparison.OrdinalIgnoreCase)) == true)
        {
            addStatus = (Loc["Secret.Msg.DuplicateKey", key], true);
            return;
        }

        await SecretService.StoreAsync(new StoreSoftwareSecretCommand(TenantId, ProjectId, addEnv, key, addValue, ActorUserId));
        await ReloadAsync();
        await LoadDetailAsync(key);
        status = (Loc["Secret.Msg.Created", key], false);
    }, !string.IsNullOrWhiteSpace(addKey));

    private Task DeleteCurrentAsync() => RunAsync(async () =>
    {
        await SecretService.DeleteSecretAsync(TenantId, ProjectId, detail!.Key, ActorUserId);
        selectedKey = null;
        detail = null;
        confirmDelete = false;
        await ReloadAsync();
        status = (Loc["Secret.Msg.Deleted"], false);
    }, detail is not null);

    private async Task RunAsync(Func<Task> action, bool precondition)
    {
        if (busy || !precondition) return;
        busy = true;
        status = null;
        addStatus = null;
        try { await action(); }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }
}
