@page "/amkeyward/secrets"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@inject ISoftwareSecretService SecretService
@inject IProjectService ProjectService
@inject ICurrentUser CurrentUser
@inject IKeywardWorkspaceContext Workspace
@inject KeywardUiState UiState
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@KeywardOptions.ProductName</PageTitle>

@* Same master-detail pattern as the vault pages: the secret keys as a list on the left (selection only),
   the selected secret's per-environment values on the right. *@
<KeywardUi Fill="true">
    <div class="page-header">
        <h1>@Loc["Page.Secrets.Title"]</h1>
        <p>@Loc["Page.Secrets.Desc"]</p>
        <details class="help">
            <summary>@Loc["Common.HowItWorks"]</summary>
            <div>
                <p>@Loc["Page.Secrets.Help"]</p>
                <p>@Loc["Secret.UsageNote"]</p>
            </div>
        </details>
    </div>

    @if (apps is null)
    {
        <p class="muted">@Loc["Common.Loading"]</p>
    }
    else
    {
        <div class="workspace">
            @* ---------- Left: applications, the selected one showing its secret keys ---------- *@
            <aside class="ws-tree">
                <div class="ws-tree-title">@Loc["Page.Apps.Title"]</div>

                @foreach (var a in apps)
                {
                    <button class="tree-node @(a.Id == selectedAppId && selectedKey is null ? "active" : "")" @onclick="() => SelectAppAsync(a.Id)">
                        <KeywardIcon Name="package" /><span class="tree-label">@a.Name</span>
                        <span class="tree-count">@a.SecretCount</span>
                    </button>
                    @if (a.Id == selectedAppId && secrets is not null)
                    {
                        <div class="tree-children">
                            @if (secrets.Count > 8)
                            {
                                <input @bind="filter" @bind:event="oninput" placeholder="@(Loc["Secret.Filter"])" aria-label="@(Loc["Secret.Filter"])" style="margin:.25rem 0 .4rem;" />
                            }

                            @foreach (var s in Filtered)
                            {
                                <button class="tree-node tree-child @(s.Key == selectedKey ? "active" : "")" @onclick="() => SelectAsync(s.Key)">
                                    <KeywardIcon Name="key" /><span class="tree-label">@s.Key</span>
                                    <span class="tree-count">@s.EnvironmentsWithValue.Count</span>
                                </button>
                            }

                            @if (secrets.Count == 0)
                            {
                                <p class="muted" style="font-size:.85rem; padding:.25rem .5rem;">@Loc["Secret.Empty"]</p>
                            }
                        </div>
                    }
                }

                @if (apps.Count == 0)
                {
                    <p class="muted" style="font-size:.85rem; padding:.25rem .5rem;">@Loc["App.Empty"]</p>
                }
            </aside>

            @* ---------- Right: add area + the selected secret's environments ---------- *@
            <section class="ws-main">
                @if (selectedAppId is null)
                {
                    <div class="card">
                        <h3>@Loc["Page.Apps.Title"]</h3>
                        <p class="muted">@Loc["App.NoneHint"]</p>
                        <div class="empty-state">
                            <KeywardIcon Name="package" Size="28" />
                            <button class="btn-sm" @onclick='() => Nav.NavigateTo(KeywardRoutes.Applications)'><KeywardIcon Name="package" Size="14" /> @Loc["App.GoToApps"]</button>
                        </div>
                    </div>
                }
                else
                {
                <details class="card section">
                    <summary><KeywardIcon Name="plus" /> @Loc["Secret.Add"]</summary>
                    <div class="section-body">
                        <p class="muted">@Loc["Secret.Desc"]</p>
                        <div class="detail-grid" style="max-width:44rem;">
                            <div class="field"><label for="kw-secret-key">@Loc["Secret.Key"]</label><input id="kw-secret-key" @bind="addKey" placeholder="ConnectionStrings:Main" /></div>
                            <div class="field">
                                <label for="kw-secret-env">@Loc["Common.Environment"]</label>
                                <select id="kw-secret-env" @bind="addEnv">
                                    @foreach (var e in environmentNames)
                                    {
                                        <option value="@e">@e</option>
                                    }
                                </select>
                            </div>
                            <div class="field wide"><label for="kw-secret-value">@Loc["Secret.Value"]</label><input id="kw-secret-value" @bind="addValue" autocomplete="off" /></div>
                            <div class="row wide">
                                <button @onclick="SaveNewAsync" disabled="@(busy || string.IsNullOrWhiteSpace(addKey))">@Loc["Common.Save"]</button>
                            </div>
                        </div>
                        @* Feedback for THIS area (created / key already exists) belongs right here. *@
                        @if (addStatus is not null)
                        {
                            <div class="notice @(addStatus.Value.IsError ? "notice-error" : "")" role="@(addStatus.Value.IsError ? "alert" : "status")">@addStatus.Value.Text</div>
                        }
                    </div>
                </details>

                @if (detail is null)
                {
                    <div class="card">
                        <h3>@Loc["Secret.Title"]</h3>
                        <p class="muted">@Loc["Secret.Desc"]</p>
                        @if (secrets is { Count: 0 })
                        {
                            <div class="empty-state">
                                <KeywardIcon Name="key" Size="28" />
                                <p>@Loc["Secret.Empty"]</p>
                            </div>
                        }
                        else
                        {
                            <p class="muted" style="font-size:.85rem;">@Loc["Secret.SelectHint"]</p>
                        }
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="row" style="justify-content:space-between;">
                            <h3 style="margin:0; display:flex; align-items:center; gap:.5rem;"><KeywardIcon Name="key" Size="18" /><code>@detail.Key</code></h3>
                            <div class="row">
                                <button class="btn-ghost btn-sm" @onclick="() => reveal = !reveal"><KeywardIcon Name="@(reveal ? "eye-off" : "eye")" Size="14" /> @(reveal ? Loc["Secret.HideValues"] : Loc["Secret.RevealValues"])</button>
                                <button class="btn-danger btn-sm" @onclick="() => confirmDelete = true" disabled="@busy">@Loc["Common.DeleteEllipsis"]</button>
                            </div>
                        </div>
                        @if (confirmDelete)
                        {
                            <div class="notice notice-error" style="margin-top:.5rem;">
                                @Loc["Secret.ConfirmDelete", detail.Key]
                                <button class="btn-danger btn-sm" style="margin-left:.5rem;" @onclick="DeleteCurrentAsync" disabled="@busy">@Loc["Common.Yes"]</button>
                                <button class="btn-ghost btn-sm" @onclick="() => confirmDelete = false">@Loc["Common.Cancel"]</button>
                            </div>
                        }
                        <p class="muted">@Loc["Secret.View.Desc"]</p>
                        <div class="table-scroll">
                            <table style="table-layout:fixed; width:100%;">
                                <thead>
                                    <tr>
                                        <th style="width:11rem;">@Loc["Common.Environment"]</th>
                                        <th style="width:50%;">@Loc["Secret.CurrentValue"]</th>
                                        <th style="width:50%;">@Loc["Secret.SetNewValue"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var env in detail.Environments)
                                    {
                                        var shown = reveal || revealedEnvironments.Contains(env.Environment);
                                        <tr>
                                            <td>@env.Environment</td>
                                            <td>
                                                <div class="row" style="flex-wrap:nowrap;">
                                                    <code style="flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis;">@(env.HasValue ? (shown ? env.Value : "••••••••") : "—")</code>
                                                    @if (env.HasValue)
                                                    {
                                                        <button class="icon-btn" title="@(shown ? Loc["Common.Hide"] : Loc["Common.Reveal"])" @onclick="() => ToggleRowReveal(env.Environment)"><KeywardIcon Name="@(shown ? "eye-off" : "eye")" Size="15" /></button>
                                                    }
                                                </div>
                                            </td>
                                            <td>
                                                <div class="row" style="flex-wrap:nowrap;">
                                                    <input @bind="editValues[env.Environment]" placeholder="@(Loc["Secret.NewValuePlaceholder"])" aria-label="@(Loc["Secret.SetNewValue"])" autocomplete="off" style="flex:1; min-width:0;" />
                                                    <button class="btn-sm" @onclick="() => SetValueAsync(env.Environment)" disabled="@(busy || string.IsNullOrEmpty(editValues[env.Environment]))">@Loc["Common.Save"]</button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                }

                @if (status is not null)
                {
                    <div class="notice @(status.Value.IsError ? "notice-error" : "")" role="@(status.Value.IsError ? "alert" : "status")">@status.Value.Text</div>
                }
            </section>
        </div>
    }
</KeywardUi>

@code {
    private Guid? actorUserId;
    private IReadOnlyList<ProjectInfo>? apps;
    private Guid? selectedAppId;
    private IReadOnlyList<SoftwareSecretSummary>? secrets;
    private string? selectedKey;
    private SoftwareSecretDetail? detail;
    private bool reveal;
    private readonly HashSet<string> revealedEnvironments = [];
    private bool confirmDelete;
    private string filter = "";

    // environments (per project; managed on the Environments admin page, this list feeds the select)
    private IReadOnlyList<string> environmentNames = [];

    private string addKey = "";
    private string addEnv = "Development";
    private string addValue = "";

    private readonly Dictionary<string, string> editValues = new();

    private (string Text, bool IsError)? status;
    private (string Text, bool IsError)? addStatus;
    private bool busy;

    private IEnumerable<SoftwareSecretSummary> Filtered =>
        secrets is null ? []
        : string.IsNullOrWhiteSpace(filter) ? secrets
        : secrets.Where(s => s.Key.Contains(filter.Trim(), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        actorUserId = CurrentUser.UserId;
        apps = await ProjectService.ListAsync(Workspace.TenantId);
        // Open the application remembered from the Applications page (or the only/first one).
        var initial = apps.FirstOrDefault(a => a.Id == UiState.SelectedProjectId) ?? apps.FirstOrDefault();
        if (initial is not null)
        {
            await LoadAppAsync(initial.Id);
        }
    }

    private Task SelectAppAsync(Guid appId) => RunAsync(() => LoadAppAsync(appId), true);

    private async Task LoadAppAsync(Guid appId)
    {
        selectedAppId = appId;
        UiState.SelectedProjectId = appId;
        selectedKey = null;
        detail = null;
        filter = "";
        confirmDelete = false;
        environmentNames = (await SecretService.ListEnvironmentsAsync(Workspace.TenantId, appId)).Select(e => e.Name).ToList();
        if (!environmentNames.Contains(addEnv))
        {
            addEnv = environmentNames.FirstOrDefault() ?? addEnv;
        }
        await ReloadAsync();
        // A single secret is the common case early on — open it right away.
        if (secrets is { Count: 1 })
        {
            await LoadDetailAsync(secrets[0].Key);
        }
    }

    private async Task ReloadAsync() =>
        secrets = await SecretService.ListSecretsAsync(Workspace.TenantId, selectedAppId!.Value);

    private Task SelectAsync(string key) => RunAsync(() => LoadDetailAsync(key), true);

    // Unguarded loader so handlers that already run inside RunAsync (busy == true) can refresh the
    // detail view — calling the guarded SelectAsync from there would early-return and skip the refresh.
    private async Task LoadDetailAsync(string key)
    {
        selectedKey = key;
        detail = await SecretService.GetSecretAsync(Workspace.TenantId, selectedAppId!.Value, key);
        reveal = false;
        revealedEnvironments.Clear();
        confirmDelete = false;
        editValues.Clear();
        if (detail is not null)
        {
            foreach (var e in detail.Environments)
            {
                editValues[e.Environment] = "";
            }
        }
    }

    private void ToggleRowReveal(string environment)
    {
        if (!revealedEnvironments.Add(environment))
        {
            revealedEnvironments.Remove(environment);
        }
    }

    private Task SetValueAsync(string environment) => RunAsync(async () =>
    {
        var key = detail!.Key;
        await SecretService.StoreAsync(new StoreSoftwareSecretCommand(Workspace.TenantId, selectedAppId!.Value, environment, key, editValues[environment], actorUserId));
        await LoadDetailAsync(key);
        await ReloadAsync();
        status = (Loc["Secret.Msg.Saved", key, environment], false);
    }, detail is not null && !string.IsNullOrEmpty(editValues.GetValueOrDefault(environment)));

    private Task SaveNewAsync() => RunAsync(async () =>
    {
        var key = addKey.Trim();

        // The add area creates NEW keys only — an existing key's values are changed deliberately in the
        // per-environment table below, so a duplicate here is almost certainly a mistake.
        if (secrets?.Any(s => s.Key.Equals(key, StringComparison.OrdinalIgnoreCase)) == true)
        {
            addStatus = (Loc["Secret.Msg.DuplicateKey", key], true);
            return;
        }

        await SecretService.StoreAsync(new StoreSoftwareSecretCommand(Workspace.TenantId, selectedAppId!.Value, addEnv, key, addValue, actorUserId));
        addKey = "";
        addValue = "";
        await ReloadAsync();
        await LoadDetailAsync(key);
        addStatus = (Loc["Secret.Msg.Created", key], false);
    }, !string.IsNullOrWhiteSpace(addKey));

    private Task DeleteCurrentAsync() => RunAsync(async () =>
    {
        await SecretService.DeleteSecretAsync(Workspace.TenantId, selectedAppId!.Value, detail!.Key, actorUserId);
        selectedKey = null;
        detail = null;
        confirmDelete = false;
        await ReloadAsync();
        status = (Loc["Secret.Msg.Deleted"], false);
    }, detail is not null);

    private async Task RunAsync(Func<Task> action, bool precondition)
    {
        if (busy || !precondition) return;
        busy = true;
        status = null;
        addStatus = null;
        try { await action(); }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }
}
