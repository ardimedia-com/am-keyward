@page "/amkeyward/secrets"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@inject ISoftwareSecretService SecretService
@inject ICurrentUser CurrentUser
@inject IKeywardWorkspaceContext Workspace
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>AM KEYWARD</PageTitle>

<KeywardUi>
<div class="page-header">
    <h1>@Loc["Page.Secrets.Title"]</h1>
    <p>@Loc["Page.Secrets.Desc"]</p>
</div>

@if (status is not null)
{
    <div class="notice @(status.Value.IsError ? "notice-error" : "")" role="@(status.Value.IsError ? "alert" : "status")">@status.Value.Text</div>
}

<div class="notice">@Loc["Secret.UsageNote"]</div>

<div class="card">
    <div class="row" style="justify-content:space-between;">
        <h3 style="margin:0;">@Loc["Secret.Title"]</h3>
        <button class="btn-sm" @onclick="StartAdd" disabled="@busy">@Loc["Secret.Add"]</button>
    </div>
    <p class="muted">@Loc["Secret.Desc"]</p>

    @if (mode == "view" && detail is not null)
    {
        <div class="panel">
            <div class="row" style="justify-content:space-between;">
                <h4 style="margin:0;"><code>@detail.Key</code></h4>
                <div class="row">
                    <button class="btn-ghost btn-sm" @onclick="() => reveal = !reveal">@(reveal ? Loc["Secret.HideValues"] : Loc["Secret.RevealValues"])</button>
                    <button class="btn-danger btn-sm" @onclick="DeleteCurrentAsync" disabled="@busy">@Loc["Common.Delete"]</button>
                    <button class="btn-ghost btn-sm" @onclick="BackToList">@Loc["Common.Close"]</button>
                </div>
            </div>
            <p class="muted">@Loc["Secret.View.Desc"]</p>
            <div class="table-scroll">
            <table>
                <thead><tr><th>@Loc["Common.Environment"]</th><th>@Loc["Secret.CurrentValue"]</th><th>@Loc["Secret.SetNewValue"]</th></tr></thead>
                <tbody>
                    @foreach (var env in detail.Environments)
                    {
                        <tr>
                            <td>@env.Environment</td>
                            <td><code>@(env.HasValue ? (reveal ? env.Value : "••••••••") : "—")</code></td>
                            <td>
                                <div class="row">
                                    <input @bind="editValues[env.Environment]" placeholder="@(Loc["Secret.NewValuePlaceholder"])" aria-label="@(Loc["Secret.SetNewValue"])" autocomplete="off" style="max-width:18rem;" />
                                    <button class="btn-sm" @onclick="() => SetValueAsync(env.Environment)" disabled="@(busy || string.IsNullOrEmpty(editValues[env.Environment]))">@Loc["Common.Save"]</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
    }
    else if (mode == "add")
    {
        <div class="panel">
            <h4 style="margin-top:0;">@Loc["Secret.Add"]</h4>
            <div class="stack" style="max-width:32rem;">
                <div class="field"><label for="kw-secret-key">@Loc["Secret.Key"]</label><input id="kw-secret-key" @bind="addKey" placeholder="ConnectionStrings:Main" /></div>
                <div class="field">
                    <label for="kw-secret-env">@Loc["Common.Environment"]</label>
                    <select id="kw-secret-env" @bind="addEnv">
                        @foreach (var e in EnvironmentName.DefaultSet)
                        {
                            <option value="@e.Value">@e.Value</option>
                        }
                    </select>
                </div>
                <div class="field"><label for="kw-secret-value">@Loc["Secret.Value"]</label><input id="kw-secret-value" @bind="addValue" autocomplete="off" /></div>
                <div class="row">
                    <button @onclick="SaveNewAsync" disabled="@(busy || string.IsNullOrWhiteSpace(addKey))">@Loc["Common.Save"]</button>
                    <button class="btn-ghost" @onclick="BackToList">@Loc["Common.Cancel"]</button>
                </div>
            </div>
        </div>
    }

    @if (secrets is null)
    {
        <p class="muted">@Loc["Common.Loading"]</p>
    }
    else if (secrets.Count == 0)
    {
        <p class="muted">@Loc["Secret.Empty"]</p>
    }
    else
    {
        @if (secrets.Count > 5)
        {
            <input @bind="filter" @bind:event="oninput" placeholder="@(Loc["Secret.Filter"])" aria-label="@(Loc["Secret.Filter"])" style="max-width:18rem; margin-bottom:.5rem;" />
        }
        <div class="table-scroll">
        <table>
            <thead><tr><th>@Loc["Secret.Key"]</th><th>@Loc["Secret.EnvWithValue"]</th><th></th></tr></thead>
            <tbody>
                @foreach (var s in Filtered)
                {
                    <tr>
                        <td><code>@s.Key</code></td>
                        <td>
                            @if (s.EnvironmentsWithValue.Count == 0)
                            {
                                <span class="muted">@Loc["Secret.None"]</span>
                            }
                            else
                            {
                                @foreach (var e in s.EnvironmentsWithValue)
                                {
                                    <span class="badge" style="margin-right:.25rem;">@e</span>
                                }
                            }
                        </td>
                        <td>
                            <div class="row-actions">
                                <button class="btn-ghost btn-sm" @onclick="() => ViewAsync(s.Key)" disabled="@busy">@Loc["Common.View"]</button>
                                <button class="btn-ghost btn-sm" @onclick="() => ViewAsync(s.Key)" disabled="@busy">@Loc["Common.DeleteEllipsis"]</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>
</KeywardUi>

@code {
    private Guid? actorUserId;
    private IReadOnlyList<SoftwareSecretSummary>? secrets;
    private string mode = "list";
    private SoftwareSecretDetail? detail;
    private bool reveal;
    private string filter = "";

    private string addKey = "";
    private string addEnv = "Development";
    private string addValue = "";

    private readonly Dictionary<string, string> editValues = new();

    private (string Text, bool IsError)? status;
    private bool busy;

    private IEnumerable<SoftwareSecretSummary> Filtered =>
        secrets is null ? []
        : string.IsNullOrWhiteSpace(filter) ? secrets
        : secrets.Where(s => s.Key.Contains(filter.Trim(), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        actorUserId = CurrentUser.UserId;
        await ReloadAsync();
    }

    private async Task ReloadAsync() =>
        secrets = await SecretService.ListSecretsAsync(Workspace.TenantId, Workspace.ProjectId);

    private void StartAdd()
    {
        mode = "add";
        addKey = ""; addEnv = "Development"; addValue = "";
    }

    private Task ViewAsync(string key) => RunAsync(() => LoadDetailAsync(key), true);

    // Unguarded loader so handlers that already run inside RunAsync (busy == true) can refresh the
    // detail view — calling the guarded ViewAsync from there would early-return and skip the refresh.
    private async Task LoadDetailAsync(string key)
    {
        detail = await SecretService.GetSecretAsync(Workspace.TenantId, Workspace.ProjectId, key);
        reveal = false;
        editValues.Clear();
        if (detail is not null)
        {
            foreach (var e in detail.Environments)
            {
                editValues[e.Environment] = "";
            }
        }
        mode = "view";
    }

    private Task SetValueAsync(string environment) => RunAsync(async () =>
    {
        var key = detail!.Key;
        await SecretService.StoreAsync(new StoreSoftwareSecretCommand(Workspace.TenantId, Workspace.ProjectId, environment, key, editValues[environment], actorUserId));
        await LoadDetailAsync(key);
        await ReloadAsync();
        status = (Loc["Secret.Msg.Saved", key, environment], false);
    }, detail is not null && !string.IsNullOrEmpty(editValues.GetValueOrDefault(environment)));

    private Task SaveNewAsync() => RunAsync(async () =>
    {
        await SecretService.StoreAsync(new StoreSoftwareSecretCommand(Workspace.TenantId, Workspace.ProjectId, addEnv, addKey, addValue, actorUserId));
        var key = addKey;
        addValue = "";
        await ReloadAsync();
        await LoadDetailAsync(key);
        status = (Loc["Secret.Msg.Created", key], false);
    }, !string.IsNullOrWhiteSpace(addKey));

    private Task DeleteCurrentAsync() => RunAsync(async () =>
    {
        await SecretService.DeleteSecretAsync(Workspace.TenantId, Workspace.ProjectId, detail!.Key, actorUserId);
        await ReloadAsync();
        BackToList();
        status = (Loc["Secret.Msg.Deleted"], false);
    }, detail is not null);

    private void BackToList()
    {
        mode = "list";
        detail = null;
        reveal = false;
    }

    private async Task RunAsync(Func<Task> action, bool precondition)
    {
        if (busy || !precondition) return;
        busy = true;
        status = null;
        try { await action(); }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }
}
