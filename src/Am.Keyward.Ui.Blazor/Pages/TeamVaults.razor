@page "/amkeyward/vaults/team"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@KeywardOptions.ProductName</PageTitle>

<KeywardUi Fill="true">
    <div class="page-header">
        <h1>@Loc["Page.Team.Title"]</h1>
        <p>@Loc["Page.Team.Desc"]</p>
        <details class="help">
            <summary>@Loc["Common.HowItWorks"]</summary>
            <div>@Loc["Page.Team.Help"]</div>
        </details>
    </div>

    <VaultWorkspace Team="true" />
</KeywardUi>
