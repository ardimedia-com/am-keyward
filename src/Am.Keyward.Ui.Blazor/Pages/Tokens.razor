@page "/amkeyward/tokens"
@* Prerender disabled: loads tenant-scoped data in OnInitializedAsync, set by the circuit handler. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@inject ISoftwareClientTokenService TokenService
@inject ISoftwareSecretService SecretService
@inject IProjectService ProjectService
@inject ICurrentUser CurrentUser
@inject IKeywardWorkspaceContext Workspace
@inject KeywardUiState UiState
@inject NavigationManager NavMgr
@inject IStringLocalizer<SharedResource> Loc
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>@KeywardOptions.ProductName</PageTitle>

@* Same master-detail pattern as the vault pages: the tokens as a list on the left (selection only), the
   selected token's details and actions on the right. *@
<KeywardUi Fill="true">
    <div class="page-header">
        <h1>@Loc["Page.Tokens.Title"]</h1>
        <p>@Loc["Page.Tokens.Desc"]</p>
        <details class="help">
            <summary>@Loc["Common.HowItWorks"]</summary>
            <div>
                <p>@Loc["Page.Tokens.Help", KeywardOptions.ProductName]</p>
                <p>@Loc["Token.UsageNote"]</p>
            </div>
        </details>
    </div>

    @if (apps is null)
    {
        <p class="muted">@Loc["Common.Loading"]</p>
    }
    else
    {
        <div class="workspace">
            @* ---------- Left: applications, the selected one showing its tokens ---------- *@
            <aside class="ws-tree">
                <div class="ws-tree-title">@Loc["Page.Apps.Title"]</div>

                @foreach (var a in apps)
                {
                    <button class="tree-node @(a.Id == selectedAppId && selectedTokenId is null ? "active" : "")" @onclick="() => SelectAppAsync(a.Id)">
                        <KeywardIcon Name="package" /><span class="tree-label">@a.Name</span>
                        <span class="tree-count">@a.TokenCount</span>
                    </button>
                    @if (a.Id == selectedAppId && list is not null)
                    {
                        <div class="tree-children">
                            @if (list.Count > 8)
                            {
                                <input @bind="tokenFilter" @bind:event="oninput" placeholder="@(Loc["Token.Filter"])" aria-label="@(Loc["Token.Filter"])" style="margin:.25rem 0 .4rem;" />
                            }

                            @foreach (var row in FilteredTokens)
                            {
                                <button class="tree-node tree-child @(row.Id == selectedTokenId ? "active" : "")" @onclick="() => SelectToken(row.Id)">
                                    <KeywardIcon Name="ticket" /><span class="tree-label">@row.Name</span>
                                    <span class="tree-count"><span class="badge @StatusBadge(row)">@StatusOf(row)</span></span>
                                </button>
                            }

                            @if (list.Count == 0)
                            {
                                <p class="muted" style="font-size:.85rem; padding:.25rem .5rem;">@Loc["Token.Empty"]</p>
                            }
                        </div>
                    }
                }

                @if (apps.Count == 0)
                {
                    <p class="muted" style="font-size:.85rem; padding:.25rem .5rem;">@Loc["App.Empty"]</p>
                }
            </aside>

            @* ---------- Right: issue area + the selected token's details ---------- *@
            <section class="ws-main">
                @if (selectedAppId is null)
                {
                    <div class="card">
                        <h3>@Loc["Page.Apps.Title"]</h3>
                        <p class="muted">@Loc["App.NoneHint"]</p>
                        <div class="empty-state">
                            <KeywardIcon Name="package" Size="28" />
                            <button class="btn-sm" @onclick='() => NavMgr.NavigateTo(KeywardRoutes.Applications)'><KeywardIcon Name="package" Size="14" /> @Loc["App.GoToApps"]</button>
                        </div>
                    </div>
                }
                else
                {
                <details class="card section">
                    <summary><KeywardIcon Name="plus" /> @Loc["Token.Issue.Title"]</summary>
                    <div class="section-body">
                        <p class="muted">@Loc["Token.Issue.Desc"]</p>
                        <div class="detail-grid" style="max-width:44rem;">
                            <div class="field">
                                <label for="kw-token-env">@Loc["Common.Environment"]</label>
                                <select id="kw-token-env" @bind="environment">
                                    @foreach (var env in environments)
                                    {
                                        <option>@env</option>
                                    }
                                </select>
                            </div>
                            @* Left empty, the server assigns "<application>-<environment>" (numbered when taken). *@
                            <div class="field"><label for="kw-token-name">@Loc["Token.NameOptional"]</label><input id="kw-token-name" @bind="name" @bind:event="oninput" placeholder="@AutoName()" /></div>
                            <div class="field">
                                <label for="kw-token-expires">@Loc["Token.ExpiresInDays"]</label>
                                <select id="kw-token-expires" @bind="expiresChoice" style="max-width:10rem;">
                                    @foreach (var days in ExpiryChoices)
                                    {
                                        <option value="@days">@days</option>
                                    }
                                    <option value="">@Loc["Token.Expires.Never"]</option>
                                </select>
                            </div>
                            <div class="field"><label for="kw-token-note">@Loc["Token.NoteOptional"]</label><textarea id="kw-token-note" rows="2" @bind="note" placeholder="@(Loc["Token.NotePlaceholder"])"></textarea></div>
                            <div class="row wide">
                                <button @onclick="IssueAsync" disabled="@busy">@Loc["Token.Issue.Action"]</button>
                            </div>
                        </div>
                    </div>
                </details>

                @if (Selected is not { } token)
                {
                    <div class="card">
                        <h3>@Loc["Token.Existing.Title"]</h3>
                        <p class="muted">@Loc["Token.Existing.Desc"]</p>
                        @if (list is { Count: 0 })
                        {
                            <div class="empty-state">
                                <KeywardIcon Name="ticket" Size="28" />
                                <p>@Loc["Token.Empty"]</p>
                            </div>
                        }
                        else
                        {
                            <p class="muted" style="font-size:.85rem;">@Loc["Token.SelectHint"]</p>
                        }
                    </div>
                }
                else
                {
                    <div class="card">
                        @* Header: the name and note are edited right here, where the title sits. *@
                        <div class="row" style="justify-content:space-between; flex-wrap:wrap;">
                            <div class="row" style="flex:1; min-width:20rem; flex-wrap:nowrap;">
                                <KeywardIcon Name="ticket" Size="18" />
                                <input @bind="editName" aria-label="@(Loc["Common.Name"])" style="max-width:14rem; font-weight:600;" />
                                <input @bind="editNote" aria-label="@(Loc["Common.Note"])" placeholder="@(Loc["Token.NoteOptional"])" style="max-width:18rem;" />
                                <button class="btn-ghost btn-sm" @onclick="SaveEditAsync" disabled="@(busy || string.IsNullOrWhiteSpace(editName))">@Loc["Common.Save"]</button>
                            </div>
                            <div class="row">
                                @if (token.RevokedAt is null)
                                {
                                    @if (!token.HasSecret)
                                    {
                                        @* Pending placeholder: mint its first value (shown once, below). *@
                                        <select @bind="mintExpiryChoice" aria-label="@(Loc["Token.ExpiresInDays"])" style="max-width:7rem;">
                                            @foreach (var days in ExpiryChoices)
                                            {
                                                <option value="@days">@days</option>
                                            }
                                            <option value="">@Loc["Token.Expires.Never"]</option>
                                        </select>
                                        <button class="btn-sm" @onclick="() => MintAsync(token.Id)" disabled="@busy">@Loc["Token.GenerateValue"]</button>
                                    }
                                    else
                                    {
                                        <button class="btn-ghost btn-sm" @onclick="() => RotateAsync(token.Id)" disabled="@busy">@Loc["Token.Rotate"]</button>
                                        <button class="btn-danger btn-sm" @onclick="() => { confirmRevoke = true; confirmDelete = false; }" disabled="@busy">@Loc["Token.Revoke"]</button>
                                    }
                                }
                                else
                                {
                                    <button class="btn-ghost btn-sm" @onclick="() => ReactivateAsync(token.Id)" disabled="@busy">@Loc["Token.Reactivate"]</button>
                                }
                                <button class="btn-danger btn-sm" @onclick="() => { confirmDelete = true; confirmRevoke = false; }" disabled="@busy">@Loc["Common.DeleteEllipsis"]</button>
                            </div>
                        </div>
                        @if (confirmRevoke)
                        {
                            <div class="notice notice-error" style="margin-top:.5rem;">
                                @Loc["Token.ConfirmRevoke", token.Name]
                                <button class="btn-danger btn-sm" style="margin-left:.5rem;" @onclick="() => RevokeAsync(token.Id)" disabled="@busy">@Loc["Common.Yes"]</button>
                                <button class="btn-ghost btn-sm" @onclick="() => confirmRevoke = false">@Loc["Common.Cancel"]</button>
                            </div>
                        }
                        @if (confirmDelete)
                        {
                            <div class="notice notice-error" style="margin-top:.5rem;">
                                @Loc["Token.ConfirmDelete", token.Name]
                                <button class="btn-danger btn-sm" style="margin-left:.5rem;" @onclick="() => DeleteAsync(token.Id)" disabled="@busy">@Loc["Common.Yes"]</button>
                                <button class="btn-ghost btn-sm" @onclick="() => confirmDelete = false">@Loc["Common.Cancel"]</button>
                            </div>
                        }
                        <p class="muted" style="margin-top:.25rem;"><span class="badge @StatusBadge(token)">@StatusOf(token)</span></p>

                        <div class="detail-grid">
                            <div class="detail-field">
                                <label>@Loc["Common.Environment"]</label>
                                <div class="detail-value"><span class="grow">@EnvName(token.EnvironmentId)</span></div>
                            </div>
                            <div class="detail-field">
                                <label>@Loc["Token.Prefix"]</label>
                                <div class="detail-value"><span class="grow">@if (token.HasSecret) { <code>@token.TokenPrefix</code> } else { <text>—</text> }</span></div>
                            </div>
                            <div class="detail-field">
                                <label>@Loc["Token.Created"]</label>
                                <div class="detail-value"><span class="grow">@token.CreatedAt.UtcDateTime.ToString("u")</span></div>
                            </div>
                            <div class="detail-field">
                                <label>@Loc["Token.Expires"]</label>
                                <div class="detail-value"><span class="grow">@(token.ExpiresAt?.UtcDateTime.ToString("u") ?? "—")</span></div>
                            </div>
                        </div>

                        @* The freshly issued/rotated secret — shown exactly once, only under ITS token. *@
                        @if (issuedToken is not null && issuedForTokenId == token.Id)
                        {
                            <div class="notice notice-reveal" role="status" style="margin-top:1rem;">
                                @Loc["Token.New"]
                                <div class="row" style="flex-wrap:nowrap; margin-top:.3rem;">
                                    <code style="flex:1; min-width:0; overflow-wrap:anywhere;">@issuedToken</code>
                                    <button class="icon-btn" title="@Loc["Common.Copy"]" @onclick="CopyIssuedAsync"><KeywardIcon Name="@(issuedCopied ? "check" : "copy")" Size="15" /></button>
                                </div>
                            </div>
                        }
                    </div>
                }
                }

                @if (status is not null)
                {
                    <div class="notice @(status.Value.IsError ? "notice-error" : "")" role="@(status.Value.IsError ? "alert" : "status")">@status.Value.Text</div>
                }
            </section>
        </div>
    }
</KeywardUi>

@code {
    private static readonly int[] ExpiryChoices = [1, 10, 30, 60, 90, 180, 360];

    private IReadOnlyList<ProjectInfo>? apps;
    private Guid? selectedAppId;
    private IReadOnlyList<string> environments = [];
    private Dictionary<Guid, string> environmentNamesById = [];
    private string environment = "Production";
    private string name = "";
    private string note = "";
    private string expiresChoice = "90";
    private (string Text, bool IsError)? status;
    private string? issuedToken;
    private bool busy;
    private Guid? actorUserId;
    private IReadOnlyList<SoftwareClientTokenInfo>? list;
    private string tokenFilter = "";

    private Guid? selectedTokenId;
    private Guid? issuedForTokenId;
    private bool issuedCopied;
    private bool confirmRevoke;
    private bool confirmDelete;
    private string mintExpiryChoice = "90";
    private string editName = "";
    private string editNote = "";

    private SoftwareClientTokenInfo? Selected => list?.FirstOrDefault(t => t.Id == selectedTokenId);

    private IEnumerable<SoftwareClientTokenInfo> FilteredTokens =>
        list is null ? []
        : string.IsNullOrWhiteSpace(tokenFilter) ? list
        : list.Where(t => $"{t.Name} {t.Note} {t.TokenPrefix}".Contains(tokenFilter.Trim(), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        // The freshly issued value is shown exactly once, for THIS visit: any navigation discards it.
        NavMgr.LocationChanged += OnLocationChanged;
        actorUserId = CurrentUser.UserId;
        apps = await ProjectService.ListAsync(Workspace.TenantId);
        // Open the application remembered from the Applications page (or the only/first one).
        var initial = apps.FirstOrDefault(a => a.Id == UiState.SelectedProjectId) ?? apps.FirstOrDefault();
        if (initial is not null)
        {
            await LoadAppAsync(initial.Id);
        }
    }

    private Task SelectAppAsync(Guid appId) => RunGuardedAsync(() => LoadAppAsync(appId));

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        issuedToken = null;
        issuedForTokenId = null;
    }

    public void Dispose() => NavMgr.LocationChanged -= OnLocationChanged;

    private async Task LoadAppAsync(Guid appId)
    {
        selectedAppId = appId;
        UiState.SelectedProjectId = appId;
        list = null; // don't render the PREVIOUS app's tokens under the new app while loading
        selectedTokenId = null;
        tokenFilter = "";
        confirmRevoke = false;
        confirmDelete = false;
        issuedToken = null;
        issuedForTokenId = null;
        var envInfos = await SecretService.ListEnvironmentsAsync(Workspace.TenantId, appId);
        environments = envInfos.Select(e => e.Name).ToList();
        environmentNamesById = envInfos.ToDictionary(e => e.Id, e => e.Name);
        if (!environments.Contains(environment))
        {
            environment = environments.FirstOrDefault() ?? environment;
        }
        name = "";
        await RefreshAsync();
        // A single token is the common case early on — open it right away.
        if (list is { Count: 1 })
        {
            SelectToken(list[0].Id);
        }
    }

    private async Task RunGuardedAsync(Func<Task> action)
    {
        if (busy) return;
        busy = true; status = null;
        try { await action(); }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }

    private async Task RefreshAsync() => list = await TokenService.ListAsync(Workspace.TenantId, selectedAppId!.Value);

    private void SelectToken(Guid tokenId)
    {
        // The freshly issued value survives only while ITS token stays selected — selecting any other
        // token discards it for good (it is shown exactly once).
        if (issuedForTokenId is { } issuedId && issuedId != tokenId)
        {
            issuedToken = null;
            issuedForTokenId = null;
        }

        selectedTokenId = tokenId;
        confirmRevoke = false;
        confirmDelete = false;
        editName = Selected?.Name ?? "";
        editNote = Selected?.Note ?? "";
    }

    private string EnvName(Guid environmentId) =>
        environmentNamesById.TryGetValue(environmentId, out var n) ? n : "—";

    // What the server will assign when the name is left empty — shown as the input's placeholder.
    private string AutoName() =>
        apps?.FirstOrDefault(a => a.Id == selectedAppId) is { } app
            ? $"{app.Name.ToLowerInvariant()}-{environment.ToLowerInvariant()}"
            : "";

    private async Task IssueAsync()
    {
        if (busy || selectedAppId is null) return;
        busy = true; status = null; issuedToken = null;
        try
        {
            var expiresAt = int.TryParse(expiresChoice, out var days) ? DateTimeOffset.UtcNow.AddDays(days) : (DateTimeOffset?)null;
            var issued = await TokenService.IssueAsync(
                new IssueSoftwareClientTokenCommand(Workspace.TenantId, selectedAppId!.Value, environment, name, expiresAt, actorUserId, note));
            issuedToken = issued.Token;
            issuedForTokenId = issued.TokenId;
            issuedCopied = false;
            name = ""; note = "";
            await RefreshAsync();
            // The server may have auto-assigned the name — report the one it actually gave.
            var issuedName = list?.FirstOrDefault(t => t.Id == issued.TokenId)?.Name ?? "";
            status = (Loc["Token.Msg.Issued", issuedName, environment], false);
            SelectToken(issued.TokenId);
        }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }

    private async Task SaveEditAsync()
    {
        if (busy || selectedTokenId is null || string.IsNullOrWhiteSpace(editName)) return;
        busy = true; status = null;
        try
        {
            await TokenService.UpdateAsync(Workspace.TenantId, selectedTokenId.Value, editName, editNote, actorUserId);
            await RefreshAsync();
            status = (Loc["Token.Msg.Updated"], false);
        }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }

    // Mints the FIRST value of a pending placeholder (technically a rotation with an explicit expiry).
    private async Task MintAsync(Guid tokenId)
    {
        if (busy) return;
        busy = true; status = null; issuedToken = null;
        try
        {
            var expiresAt = int.TryParse(mintExpiryChoice, out var days) ? DateTimeOffset.UtcNow.AddDays(days) : (DateTimeOffset?)null;
            var minted = await TokenService.RotateAsync(Workspace.TenantId, tokenId, expiresAt, actorUserId);
            issuedToken = minted.Token;
            issuedForTokenId = tokenId;
            issuedCopied = false;
            status = (Loc["Token.Msg.Generated"], false);
            await RefreshAsync();
        }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }

    private async Task RotateAsync(Guid tokenId)
    {
        if (busy) return;
        busy = true; status = null; issuedToken = null;
        try
        {
            var rotated = await TokenService.RotateAsync(Workspace.TenantId, tokenId, null, actorUserId);
            issuedToken = rotated.Token;
            issuedForTokenId = tokenId;
            issuedCopied = false;
            status = (Loc["Token.Msg.Rotated"], false);
            await RefreshAsync();
        }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }

    private async Task RevokeAsync(Guid tokenId)
    {
        if (busy) return;
        busy = true; status = null;
        try
        {
            await TokenService.RevokeAsync(Workspace.TenantId, tokenId, actorUserId);
            confirmRevoke = false;
            status = (Loc["Token.Msg.Revoked"], false);
            await RefreshAsync();
        }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }

    private async Task ReactivateAsync(Guid tokenId)
    {
        if (busy) return;
        busy = true; status = null;
        try
        {
            await TokenService.ReactivateAsync(Workspace.TenantId, tokenId, actorUserId);
            status = (Loc["Token.Msg.Reactivated"], false);
            await RefreshAsync();
        }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }

    private async Task DeleteAsync(Guid tokenId)
    {
        if (busy) return;
        busy = true; status = null;
        try
        {
            await TokenService.DeleteAsync(Workspace.TenantId, tokenId, actorUserId);
            confirmDelete = false;
            selectedTokenId = null;
            issuedForTokenId = null;
            issuedToken = null;
            status = (Loc["Token.Msg.Deleted"], false);
            await RefreshAsync();
        }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }

    private async Task CopyIssuedAsync()
    {
        if (issuedToken is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", issuedToken);
        issuedCopied = true;
        StateHasChanged();
        await Task.Delay(1500);
        issuedCopied = false;
    }

    private string StatusOf(SoftwareClientTokenInfo token) =>
        token.RevokedAt is not null ? Loc["Token.Status.Revoked"]
        : !token.HasSecret ? Loc["Token.Status.Pending"]
        : token.IsActive ? Loc["Token.Status.Active"]
        : Loc["Token.Status.Expired"];

    private static string StatusBadge(SoftwareClientTokenInfo token) =>
        token.RevokedAt is not null ? "badge-danger"
        : !token.HasSecret ? ""
        : token.IsActive ? "badge-success"
        : "badge-warning";
}
