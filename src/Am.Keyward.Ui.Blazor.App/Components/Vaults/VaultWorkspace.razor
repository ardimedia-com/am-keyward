@using Am.Keyward.Core.Application
@using Am.Keyward.Core.Domain
@using Am.Keyward.Ui.Blazor.App
@using Am.Keyward.Ui.Blazor.App.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@inject IVaultService VaultService
@inject AuthenticationStateProvider AuthState
@inject IStringLocalizer<SharedResource> Loc

@if (status is not null)
{
    <div class="notice @(status.Value.IsError ? "notice-error" : "")">@status.Value.Text</div>
}

@* ---------- 1. Vault list (always shown first) ---------- *@
<div class="card">
    <h3>@(Team ? Loc["Vault.List.TitleTeam"] : Loc["Vault.List.TitlePersonal"])</h3>
    <p class="muted">
        @(Team ? Loc["Vault.List.DescTeam"] : Loc["Vault.List.DescPersonal"])
    </p>

    @if (vaults is null)
    {
        <p class="muted">@Loc["Common.Loading"]</p>
    }
    else if (vaults.Count == 0)
    {
        <p class="muted">@Loc["Vault.List.Empty"]</p>
    }
    else
    {
        @if (vaults.Count > 5)
        {
            <input @bind="vaultFilter" @bind:event="oninput" placeholder="@(Loc["Vault.Filter"])" style="max-width:16rem; margin:.25rem 0;" />
        }
        <div class="row" style="margin:.25rem 0 .75rem;">
            @foreach (var v in FilteredVaults)
            {
                <button class="@(v.Id == selectedVaultId ? "" : "btn-ghost")" @onclick="() => SelectVaultAsync(v.Id)">@v.Name</button>
            }
        </div>
    }

    <div class="row">
        <input @bind="newVaultName" placeholder="@(Team ? Loc["Vault.NewNameTeam"] : Loc["Vault.NewNamePersonal"])" style="max-width:16rem;" />
        <button @onclick="CreateVaultAsync" disabled="@(busy || string.IsNullOrWhiteSpace(newVaultName))">@Loc["Vault.Create"]</button>
    </div>
</div>

@if (selectedVaultId is not null)
{
    @* ---------- 2. Selected-vault toolbar (rename / delete / import) ---------- *@
    <div class="card">
        <div class="row" style="justify-content:space-between;">
            <h3 style="margin:0;">@SelectedVaultName</h3>
            <div class="row">
                <button class="btn-ghost btn-sm" @onclick="ToggleRenameVault" disabled="@busy">@Loc["Common.Rename"]</button>
                <button class="btn-danger btn-sm" @onclick="() => confirmDeleteVault = true" disabled="@busy">@Loc["Vault.Delete"]</button>
            </div>
        </div>

        @if (renamingVault)
        {
            <div class="row" style="margin-top:.5rem;">
                <input @bind="vaultRenameValue" style="max-width:16rem;" />
                <button class="btn-sm" @onclick="RenameVaultAsync" disabled="@(busy || string.IsNullOrWhiteSpace(vaultRenameValue))">@Loc["Common.Save"]</button>
                <button class="btn-ghost btn-sm" @onclick="() => renamingVault = false">@Loc["Common.Cancel"]</button>
            </div>
        }

        @if (confirmDeleteVault)
        {
            <div class="notice notice-error" style="margin-top:.5rem;">
                @Loc["Vault.ConfirmDelete"]
                <button class="btn-danger btn-sm" style="margin-left:.5rem;" @onclick="DeleteVaultAsync" disabled="@busy">@Loc["Vault.ConfirmDeleteYes"]</button>
                <button class="btn-ghost btn-sm" @onclick="() => confirmDeleteVault = false">@Loc["Common.Cancel"]</button>
            </div>
        }

        <h4 style="margin:1rem 0 .25rem;">@Loc["Vault.Import.Title"]</h4>
        <p class="muted">@Loc["Vault.Import.Desc"]</p>
        <InputFile OnChange="OnImportFileAsync" accept=".csv" disabled="@busy" />
    </div>

    @* ---------- 3. Folders ---------- *@
    <div class="card">
        <h3>@Loc["Vault.Folders.Title"]</h3>
        <p class="muted">@Loc["Vault.Folders.Desc"]</p>
        @if (folders.Count > 0)
        {
            @if (folders.Count > 5)
            {
                <input @bind="folderFilter" @bind:event="oninput" placeholder="@(Loc["Vault.Folders.Filter"])" style="max-width:16rem; margin-bottom:.5rem;" />
            }
            <table style="margin:.5rem 0;">
                <tbody>
                    @foreach (var f in FilteredFolders)
                    {
                        <tr>
                            <td>
                                @if (renamingFolderId == f.Id)
                                {
                                    <span class="row">
                                        <input @bind="folderRenameValue" style="max-width:14rem;" />
                                        <button class="btn-sm" @onclick="() => RenameFolderAsync(f.Id)" disabled="@busy">@Loc["Common.Save"]</button>
                                        <button class="btn-ghost btn-sm" @onclick="() => renamingFolderId = null">@Loc["Common.Cancel"]</button>
                                    </span>
                                }
                                else { @f.Name }
                            </td>
                            <td class="row-actions">
                                @if (confirmDeleteFolderId == f.Id)
                                {
                                    <span class="muted">@Loc["Vault.Folders.ConfirmDelete"]</span>
                                    <button class="btn-danger btn-sm" @onclick="() => DeleteFolderAsync(f.Id)" disabled="@busy">@Loc["Common.Yes"]</button>
                                    <button class="btn-ghost btn-sm" @onclick="() => confirmDeleteFolderId = null">@Loc["Common.Cancel"]</button>
                                }
                                else
                                {
                                    <button class="btn-ghost btn-sm" @onclick="() => StartRenameFolder(f)" disabled="@busy">@Loc["Common.Rename"]</button>
                                    <button class="btn-ghost btn-sm" @onclick="() => confirmDeleteFolderId = f.Id" disabled="@busy">@Loc["Common.DeleteEllipsis"]</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <div class="row">
            <input @bind="newFolderName" placeholder="@(Loc["Vault.Folders.NewName"])" style="max-width:14rem;" />
            <button class="btn-ghost btn-sm" @onclick="AddFolderAsync" disabled="@(busy || string.IsNullOrWhiteSpace(newFolderName))">@Loc["Vault.Folders.Add"]</button>
        </div>
    </div>

    @* ---------- 4. Items: detail/edit panel above an always-visible, filterable list ---------- *@
    <div class="card">
        <div class="row" style="justify-content:space-between;">
            <h3 style="margin:0;">@Loc["Vault.Items.Title"]</h3>
            <button class="btn-sm" @onclick="StartAddItem" disabled="@busy">@Loc["Vault.Items.Add"]</button>
        </div>
        <p class="muted">@Loc["Vault.Items.Desc"]</p>

        @if (itemMode == "view" && detail is not null)
        {
            <div class="panel">
                <div class="row" style="justify-content:space-between;">
                    <h4 style="margin:0;">@detail.Name</h4>
                    <div class="row">
                        <button class="btn-ghost btn-sm" @onclick="() => EditItemAsync(detail.Id)" disabled="@busy">@Loc["Common.Edit"]</button>
                        <button class="btn-danger btn-sm" @onclick="DeleteCurrentItemAsync" disabled="@busy">@Loc["Common.Delete"]</button>
                        <button class="btn-ghost btn-sm" @onclick="BackToList">@Loc["Common.Close"]</button>
                    </div>
                </div>
                <p class="muted"><span class="badge">@detail.Type</span> @Loc["Vault.Items.InFolder"] @FolderName(detail.FolderId)</p>

                @if (detail.Type == ItemType.Login)
                {
                    var f = LoginContent.Parse(detail.Content);
                    <div class="stack" style="max-width:32rem;">
                        <div>
                            <strong>@Loc["Vault.Field.Url"]:</strong>
                            @if (string.IsNullOrWhiteSpace(f.Url)) { <text>—</text> }
                            else { <a href="@f.Url" target="_blank" rel="noreferrer">@f.Url</a> }
                        </div>
                        <div><strong>@Loc["Vault.Field.Username"]:</strong> <code>@(string.IsNullOrWhiteSpace(f.Username) ? "—" : f.Username)</code></div>
                        <div>
                            <strong>@Loc["Vault.Field.Password"]:</strong> <code>@(reveal ? (f.Password is { Length: > 0 } ? f.Password : "—") : "••••••••")</code>
                            <button class="btn-ghost btn-sm" style="margin-left:.5rem;" @onclick="() => reveal = !reveal">@(reveal ? Loc["Common.Hide"] : Loc["Common.Reveal"])</button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(f.Note)) { <div><strong>@Loc["Vault.Field.Note"]:</strong> @f.Note</div> }
                    </div>
                }
                else
                {
                    <div>
                        <strong>@Loc["Vault.Field.Value"]:</strong> <code>@(reveal ? detail.Content : "••••••••")</code>
                        <button class="btn-ghost btn-sm" style="margin-left:.5rem;" @onclick="() => reveal = !reveal">@(reveal ? Loc["Common.Hide"] : Loc["Common.Reveal"])</button>
                    </div>
                }
            </div>
        }
        else if (itemMode is "add" or "edit")
        {
            <div class="panel">
                <h4 style="margin-top:0;">@(itemMode == "add" ? Loc["Vault.Items.Add"] : Loc["Vault.Items.EditNamed", fName])</h4>
                <div class="stack" style="max-width:32rem;">
                    @if (itemMode == "add")
                    {
                        <div class="field">
                            <label>@Loc["Common.Type"]</label>
                            <select @bind="fType">
                                @foreach (var t in Enum.GetValues<ItemType>())
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="field"><label>@Loc["Common.Name"]</label><input @bind="fName" placeholder="@(Loc["Vault.Items.NamePlaceholder"])" /></div>
                    <div class="field">
                        <label>@Loc["Vault.Field.Folder"]</label>
                        <select @bind="fFolderId">
                            <option value="">@Loc["Vault.Field.NoFolder"]</option>
                            @foreach (var folder in folders)
                            {
                                <option value="@folder.Id">@folder.Name</option>
                            }
                        </select>
                    </div>

                    @if (fType == ItemType.Login)
                    {
                        <div class="field"><label>@Loc["Vault.Field.Url"]</label><input @bind="fUrl" placeholder="https://example.com" /></div>
                        <div class="field"><label>@Loc["Vault.Field.Username"]</label><input @bind="fUser" autocomplete="off" /></div>
                        <div class="field"><label>@Loc["Vault.Field.Password"]</label><input @bind="fPwd" autocomplete="off" /></div>
                        <div class="field"><label>@Loc["Vault.Field.Note"]</label><textarea rows="2" @bind="fNote"></textarea></div>
                    }
                    else
                    {
                        <div class="field"><label>@Loc["Vault.Field.ValueNote"]</label><textarea rows="4" @bind="fContent" placeholder="@(Loc["Vault.Field.ValuePlaceholder"])"></textarea></div>
                    }

                    <div class="row">
                        <button @onclick="SaveItemAsync" disabled="@(busy || string.IsNullOrWhiteSpace(fName))">@Loc["Common.Save"]</button>
                        <button class="btn-ghost" @onclick="BackToList">@Loc["Common.Cancel"]</button>
                    </div>
                </div>
            </div>
        }

        @if (items is null)
        {
            <p class="muted">@Loc["Common.Loading"]</p>
        }
        else if (items.Count == 0)
        {
            <p class="muted">@Loc["Vault.Items.Empty"]</p>
        }
        else
        {
            @if (items.Count > 5)
            {
                <input @bind="itemFilter" @bind:event="oninput" placeholder="@(Loc["Vault.Items.Filter"])" style="max-width:18rem; margin-bottom:.5rem;" />
            }
            <table>
                <thead><tr><th>@Loc["Common.Name"]</th><th>@Loc["Common.Type"]</th><th>@Loc["Vault.Field.Folder"]</th><th></th></tr></thead>
                <tbody>
                    @foreach (var item in FilteredItems)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td><span class="badge">@item.Type</span></td>
                            <td class="muted">@FolderName(item.FolderId)</td>
                            <td class="row-actions">
                                <button class="btn-ghost btn-sm" @onclick="() => ViewItemAsync(item.Id)" disabled="@busy">@Loc["Common.View"]</button>
                                <button class="btn-ghost btn-sm" @onclick="() => EditItemAsync(item.Id)" disabled="@busy">@Loc["Common.Edit"]</button>
                                <button class="btn-ghost btn-sm" @onclick="() => ViewItemAsync(item.Id)" disabled="@busy">@Loc["Common.DeleteEllipsis"]</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* ---------- 5. Sharing (team vaults only) ---------- *@
    @if (Team)
    {
        <div class="card">
            <h3>@Loc["Vault.Share.Title"]</h3>
            <p class="muted">@Loc["Vault.Share.Desc"]</p>
            @if (shareCandidates.Count == 0)
            {
                <p class="muted">@Loc["Vault.Share.NoCandidates"]</p>
            }
            else
            {
                <div class="row" style="margin:.5rem 0;">
                    <select @bind="shareGranteeId" style="max-width:16rem;">
                        <option value="">@Loc["Vault.Share.SelectUser"]</option>
                        @foreach (var c in shareCandidates)
                        {
                            <option value="@c.UserId">@c.DisplayName</option>
                        }
                    </select>
                    <select @bind="sharePermission" style="max-width:10rem;">
                        @foreach (var p in Enum.GetValues<Permission>())
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                    <button @onclick="ShareAsync" disabled="@(busy || string.IsNullOrEmpty(shareGranteeId))">@Loc["Vault.Share.Action"]</button>
                </div>
            }
            @if (shares is { Count: > 0 })
            {
                <table>
                    <thead><tr><th>@Loc["Vault.Share.User"]</th><th>@Loc["Vault.Share.Permission"]</th></tr></thead>
                    <tbody>
                        @foreach (var s in shares)
                        {
                            <tr><td>@s.DisplayName</td><td><span class="badge">@s.Permission</span></td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
}

@code {
    [Parameter] public bool Team { get; set; }

    private Guid? actorUserId;
    private readonly Guid tenantId = Demo.TenantId;

    private IReadOnlyList<VaultSummary>? vaults;
    private Guid? selectedVaultId;
    private IReadOnlyList<VaultFolderSummary> folders = [];
    private IReadOnlyList<VaultItemSummary>? items;

    private string itemMode = "list";
    private VaultItemDetail? detail;
    private bool reveal;

    // forms
    private string newVaultName = "";
    private bool renamingVault;
    private string vaultRenameValue = "";
    private bool confirmDeleteVault;
    private string newFolderName = "";
    private Guid? renamingFolderId;
    private string folderRenameValue = "";
    private Guid? confirmDeleteFolderId;

    // list filters
    private string vaultFilter = "";
    private string folderFilter = "";
    private string itemFilter = "";

    private string fName = "";
    private ItemType fType = ItemType.Login;
    private string fFolderId = "";
    private string fUrl = "", fUser = "", fPwd = "", fNote = "", fContent = "";

    // sharing (team)
    private IReadOnlyList<ShareCandidate> shareCandidates = [];
    private IReadOnlyList<VaultShare>? shares;
    private string shareGranteeId = "";
    private Permission sharePermission = Permission.Read;

    private (string Text, bool IsError)? status;
    private bool busy;

    private string SelectedVaultName => vaults?.FirstOrDefault(v => v.Id == selectedVaultId)?.Name ?? "";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (Guid.TryParse(state.User.FindFirst(KeywardUserClaimsPrincipalFactory.UserIdClaim)?.Value, out var id))
        {
            actorUserId = id;
        }

        await ReloadVaultsAsync();
    }

    private async Task ReloadVaultsAsync()
    {
        if (actorUserId is null) return;
        vaults = Team
            ? await VaultService.ListSharedVaultsAsync(actorUserId.Value, tenantId)
            : await VaultService.ListVaultsAsync(actorUserId.Value);
    }

    private async Task SelectVaultAsync(Guid vaultId)
    {
        selectedVaultId = vaultId;
        itemMode = "list";
        detail = null;
        reveal = false;
        renamingVault = false;
        confirmDeleteVault = false;
        await ReloadContentsAsync();
        if (Team)
        {
            shareCandidates = await VaultService.ListShareCandidatesAsync(actorUserId!.Value, tenantId);
            shares = await VaultService.ListVaultSharesAsync(actorUserId!.Value, vaultId);
        }
    }

    private async Task ReloadContentsAsync()
    {
        if (selectedVaultId is null) return;
        folders = await VaultService.ListFoldersAsync(actorUserId!.Value, selectedVaultId.Value);
        items = await VaultService.ListItemsAsync(actorUserId!.Value, selectedVaultId.Value);
    }

    private Task CreateVaultAsync() => RunAsync(async () =>
    {
        var id = Team
            ? await VaultService.CreateTenantVaultAsync(new CreateTenantVaultCommand(actorUserId!.Value, tenantId, newVaultName))
            : await VaultService.CreatePersonalVaultAsync(new CreatePersonalVaultCommand(actorUserId!.Value, newVaultName));
        newVaultName = "";
        await ReloadVaultsAsync();
        await SelectVaultAsync(id);
        status = (Loc["Vault.Msg.Created"], false);
    }, !string.IsNullOrWhiteSpace(newVaultName));

    private void ToggleRenameVault()
    {
        renamingVault = !renamingVault;
        vaultRenameValue = SelectedVaultName;
    }

    private Task RenameVaultAsync() => RunAsync(async () =>
    {
        await VaultService.RenameVaultAsync(actorUserId!.Value, selectedVaultId!.Value, vaultRenameValue);
        renamingVault = false;
        await ReloadVaultsAsync();
        status = (Loc["Vault.Msg.Renamed"], false);
    }, selectedVaultId is not null && !string.IsNullOrWhiteSpace(vaultRenameValue));

    private Task DeleteVaultAsync() => RunAsync(async () =>
    {
        await VaultService.DeleteVaultAsync(actorUserId!.Value, selectedVaultId!.Value);
        confirmDeleteVault = false;
        selectedVaultId = null;
        await ReloadVaultsAsync();
        status = (Loc["Vault.Msg.Deleted"], false);
    }, selectedVaultId is not null);

    private Task AddFolderAsync() => RunAsync(async () =>
    {
        await VaultService.AddFolderAsync(new AddVaultFolderCommand(actorUserId!.Value, selectedVaultId!.Value, newFolderName));
        newFolderName = "";
        await ReloadContentsAsync();
    }, selectedVaultId is not null && !string.IsNullOrWhiteSpace(newFolderName));

    private void StartRenameFolder(VaultFolderSummary f)
    {
        renamingFolderId = f.Id;
        folderRenameValue = f.Name;
    }

    private Task RenameFolderAsync(Guid folderId) => RunAsync(async () =>
    {
        await VaultService.RenameFolderAsync(actorUserId!.Value, selectedVaultId!.Value, folderId, folderRenameValue);
        renamingFolderId = null;
        await ReloadContentsAsync();
    }, !string.IsNullOrWhiteSpace(folderRenameValue));

    private Task DeleteFolderAsync(Guid folderId) => RunAsync(async () =>
    {
        await VaultService.DeleteFolderAsync(actorUserId!.Value, selectedVaultId!.Value, folderId);
        confirmDeleteFolderId = null;
        await ReloadContentsAsync();
    }, true);

    private void StartAddItem()
    {
        itemMode = "add";
        fName = ""; fType = ItemType.Login; fFolderId = ""; fUrl = ""; fUser = ""; fPwd = ""; fNote = ""; fContent = "";
    }

    private Task ViewItemAsync(Guid itemId) => RunAsync(async () =>
    {
        detail = await VaultService.GetItemAsync(actorUserId!.Value, itemId);
        reveal = false;
        itemMode = "view";
    }, true);

    private Task EditItemAsync(Guid itemId) => RunAsync(async () =>
    {
        var d = await VaultService.GetItemAsync(actorUserId!.Value, itemId);
        if (d is null) return;
        detail = d;
        fName = d.Name; fType = d.Type; fFolderId = d.FolderId?.ToString() ?? "";
        if (d.Type == ItemType.Login)
        {
            var f = LoginContent.Parse(d.Content);
            fUrl = f.Url; fUser = f.Username; fPwd = f.Password; fNote = f.Note;
        }
        else { fContent = d.Content; }
        itemMode = "edit";
    }, true);

    private Task SaveItemAsync() => RunAsync(async () =>
    {
        Guid? folderId = Guid.TryParse(fFolderId, out var fid) ? fid : null;
        var content = fType == ItemType.Login ? LoginContent.ToJson(fUrl, fUser, fPwd, fNote) : fContent;
        if (itemMode == "add")
        {
            await VaultService.AddItemAsync(new AddVaultItemCommand(actorUserId!.Value, selectedVaultId!.Value, folderId, fType, fName, content));
            status = (Loc["Vault.Msg.ItemAdded"], false);
        }
        else
        {
            await VaultService.UpdateItemAsync(new UpdateVaultItemCommand(actorUserId!.Value, detail!.Id, fName, folderId, content));
            status = (Loc["Vault.Msg.ItemSaved"], false);
        }
        await ReloadContentsAsync();
        BackToList();
    }, selectedVaultId is not null && !string.IsNullOrWhiteSpace(fName));

    private Task DeleteCurrentItemAsync() => RunAsync(async () =>
    {
        await VaultService.DeleteItemAsync(actorUserId!.Value, detail!.Id);
        await ReloadContentsAsync();
        BackToList();
        status = (Loc["Vault.Msg.ItemDeleted"], false);
    }, detail is not null);

    private async Task OnImportFileAsync(InputFileChangeEventArgs e)
    {
        await RunAsync(async () =>
        {
            using var reader = new StreamReader(e.File.OpenReadStream(maxAllowedSize: 8 * 1024 * 1024));
            var text = await reader.ReadToEndAsync();
            var logins = EdgePasswordCsv.Parse(text);
            if (logins.Count == 0) { status = (Loc["Vault.Msg.NoLogins"], true); return; }
            var count = await VaultService.ImportLoginsAsync(actorUserId!.Value, selectedVaultId!.Value, logins);
            await ReloadContentsAsync();
            status = (Loc["Vault.Msg.Imported", count], false);
        }, selectedVaultId is not null);
    }

    private Task ShareAsync() => RunAsync(async () =>
    {
        if (!Guid.TryParse(shareGranteeId, out var grantee)) return;
        await VaultService.ShareWithUserAsync(new ShareVaultWithUserCommand(actorUserId!.Value, tenantId, selectedVaultId!.Value, grantee, sharePermission));
        shareGranteeId = "";
        shares = await VaultService.ListVaultSharesAsync(actorUserId!.Value, selectedVaultId!.Value);
        status = (Loc["Vault.Msg.Shared"], false);
    }, selectedVaultId is not null && !string.IsNullOrEmpty(shareGranteeId));

    private void BackToList()
    {
        itemMode = "list";
        detail = null;
        reveal = false;
    }

    private async Task RunAsync(Func<Task> action, bool precondition)
    {
        if (busy || actorUserId is null || !precondition) return;
        busy = true;
        status = null;
        try { await action(); }
        catch (Exception ex) { status = (Loc["Common.Error"] + ex.Message, true); }
        finally { busy = false; }
    }

    private string FolderName(Guid? folderId) => folderId is null ? "—" : folders.FirstOrDefault(f => f.Id == folderId)?.Name ?? "—";

    private IEnumerable<VaultSummary> FilteredVaults => Filter(vaults, vaultFilter, v => v.Name);
    private IEnumerable<VaultFolderSummary> FilteredFolders => Filter(folders, folderFilter, f => f.Name);
    private IEnumerable<VaultItemSummary> FilteredItems => Filter(items, itemFilter, i => $"{i.Name} {i.Type}");

    private static IEnumerable<T> Filter<T>(IEnumerable<T>? source, string query, Func<T, string> selector)
    {
        if (source is null) return [];
        return string.IsNullOrWhiteSpace(query)
            ? source
            : source.Where(x => selector(x).Contains(query.Trim(), StringComparison.OrdinalIgnoreCase));
    }
}
