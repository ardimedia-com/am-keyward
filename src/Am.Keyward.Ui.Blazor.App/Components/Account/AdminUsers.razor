@page "/account/admin/users"
@attribute [Authorize(Policy = "Keyward.SystemAdmin")]
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Am.Keyward.Core.Domain
@using Am.Keyward.Infrastructure.Persistence
@inject UserManager<IdentityUser> UserManager
@inject KeywardDbContext Db
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@KeywardOptions.ProductName</PageTitle>

<div class="page-header">
    <h1>@Loc["Admin.Users.Title"]</h1>
    <p>@Loc["Admin.Users.Desc"]</p>
</div>

<div class="card">
    <div class="table-scroll">
        <table>
            <thead>
                <tr>
                    <th>@Loc["Admin.Users.User"]</th>
                    <th>@Loc["Admin.Users.Status"]</th>
                    <th>@Loc["Admin.Users.TenantRole"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in rows)
                {
                    <tr>
                        <td>
                            @row.Name
                            @if (row.IsSystemAdmin)
                            {
                                <span class="badge badge-success" style="margin-left:.4rem;">@Loc["Admin.Users.SystemAdmin"]</span>
                            }
                        </td>
                        <td>
                            @if (row.State == UserState.Disabled)
                            {
                                <span class="badge badge-danger">@Loc["Admin.Users.State.Disabled"]</span>
                            }
                            else if (row.State == UserState.LockedOut)
                            {
                                <span class="badge badge-warning">@Loc["Admin.Users.State.LockedOut"]</span>
                            }
                            else
                            {
                                <span class="badge badge-success">@Loc["Admin.Users.State.Active"]</span>
                            }
                        </td>
                        <td>
                            @if (row.TenantRole == TenantRole.TenantAdmin)
                            {
                                <span class="badge badge-success">@Loc["Admin.Users.Role.TenantAdmin"]</span>
                            }
                            else if (row.TenantRole == TenantRole.Member)
                            {
                                <span class="badge">@Loc["Admin.Users.Role.Member"]</span>
                            }
                            else
                            {
                                <span class="muted">—</span>
                            }
                        </td>
                        <td>
                            <div class="row-actions">
                                @if (row.State == UserState.LockedOut)
                                {
                                    <form method="post" action="account/admin/users/unlock">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="userId" value="@row.Id" />
                                        <button type="submit" class="btn-ghost btn-sm">@Loc["Admin.Users.Unlock"]</button>
                                    </form>
                                }
                                @if (row.State == UserState.Disabled)
                                {
                                    <form method="post" action="account/admin/users/enable">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="userId" value="@row.Id" />
                                        <button type="submit" class="btn-ghost btn-sm">@Loc["Admin.Users.Enable"]</button>
                                    </form>
                                }
                                else if (!row.IsSelf)
                                {
                                    <form method="post" action="account/admin/users/disable">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="userId" value="@row.Id" />
                                        <button type="submit" class="btn-danger btn-sm">@Loc["Admin.Users.Disable"]</button>
                                    </form>
                                }
                                @* Tenant-role actions need the domain user (created at first sign-in). Never
                                   offer demoting the LAST tenant admin — the tenant must keep one. *@
                                @if (row.HasDomainUser && row.TenantRole != TenantRole.TenantAdmin)
                                {
                                    <form method="post" action="account/admin/users/role">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="userId" value="@row.Id" />
                                        <input type="hidden" name="role" value="@nameof(TenantRole.TenantAdmin)" />
                                        <button type="submit" class="btn-ghost btn-sm">@Loc["Admin.Users.MakeTenantAdmin"]</button>
                                    </form>
                                }
                                else if (row.TenantRole == TenantRole.TenantAdmin && tenantAdminCount > 1)
                                {
                                    <form method="post" action="account/admin/users/role">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="userId" value="@row.Id" />
                                        <input type="hidden" name="role" value="@nameof(TenantRole.Member)" />
                                        <button type="submit" class="btn-ghost btn-sm">@Loc["Admin.Users.MakeMember"]</button>
                                    </form>
                                }
                                @if (CanDelete(row))
                                {
                                    <a class="btn btn-danger btn-sm" href="account/admin/users?confirmDelete=@row.Id">@Loc["Common.DeleteEllipsis"]</a>
                                }
                            </div>
                        </td>
                    </tr>
                    @if (ConfirmDelete == row.Id && CanDelete(row))
                    {
                        <tr>
                            <td colspan="4">
                                <div class="notice notice-error" style="display:flex; align-items:center; gap:.6rem; flex-wrap:wrap;">
                                    <span>@Loc["Admin.Users.ConfirmDelete", row.Name]</span>
                                    <form method="post" action="account/admin/users/delete" style="margin:0;">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="userId" value="@row.Id" />
                                        <button type="submit" class="btn-danger btn-sm">@Loc["Common.Yes"]</button>
                                    </form>
                                    <a class="btn btn-ghost btn-sm" href="account/admin/users">@Loc["Common.Cancel"]</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    [SupplyParameterFromQuery] private string? ConfirmDelete { get; set; }

    private readonly List<Row> rows = [];
    private int tenantAdminCount;
    private int systemAdminCount;

    // Mirrors the server-side guards: never self, never the last tenant admin, never the last system admin.
    private bool CanDelete(Row row) =>
        !row.IsSelf
        && !(row.TenantRole == TenantRole.TenantAdmin && tenantAdminCount <= 1)
        && !(row.IsSystemAdmin && systemAdminCount <= 1);

    private enum UserState { Active, LockedOut, Disabled }

    private sealed record Row(string Id, string Name, bool IsSystemAdmin, bool IsSelf, UserState State,
        bool HasDomainUser, TenantRole? TenantRole);

    protected override async Task OnInitializedAsync()
    {
        var currentId = AuthState is not null
            ? UserManager.GetUserId((await AuthState).User)
            : null;

        // System-admin flag and the demo-tenant membership role live on the domain side (AppUser /
        // TenantMemberships), keyed by the Identity user id for local accounts.
        var domainUsers = await Db.Users
            .Where(u => u.Issuer == null && u.ExternalId != null)
            .Select(u => new { u.Id, u.ExternalId, u.IsSystemAdmin })
            .ToListAsync();
        var byExternalId = domainUsers.ToDictionary(u => u.ExternalId!, u => u);

        var domainIds = domainUsers.Select(u => u.Id).ToList();
        var roles = await Db.TenantMemberships
            .Where(m => m.TenantId == Demo.TenantId && domainIds.Contains(m.UserId))
            .ToDictionaryAsync(m => m.UserId, m => m.Role);

        tenantAdminCount = roles.Count(r => r.Value == TenantRole.TenantAdmin);
        systemAdminCount = domainUsers.Count(u => u.IsSystemAdmin);

        var now = DateTimeOffset.UtcNow;
        foreach (var user in UserManager.Users.OrderBy(u => u.UserName).ToList())
        {
            var state = user.LockoutEnd switch
            {
                { } end when end >= DateTimeOffset.MaxValue.AddDays(-1) => UserState.Disabled,
                { } end when end > now => UserState.LockedOut,
                _ => UserState.Active,
            };

            var domain = byExternalId.GetValueOrDefault(user.Id);
            rows.Add(new Row(
                user.Id,
                user.UserName ?? user.Email ?? user.Id,
                domain?.IsSystemAdmin ?? false,
                user.Id == currentId,
                state,
                domain is not null,
                domain is not null && roles.TryGetValue(domain.Id, out var role) ? role : null));
        }
    }
}
