@page "/account/login"
@using System.ComponentModel.DataAnnotations
@using System.Text
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using Am.Keyward.Ui.Blazor.App.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject IAccountEmailSender EmailSender
@inject ILogger<Login> Logger
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>AM KEYWARD</PageTitle>

<h1>@Loc["Login.Title"]</h1>

@if (infoMessage is not null)
{
    <div class="notice" role="status">@infoMessage</div>
}
@if (errorMessage is not null)
{
    <p style="color:#b00020;"><strong>@errorMessage</strong></p>
}

<EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
    <DataAnnotationsValidator />
    <div style="display:flex; flex-direction:column; gap:.5rem; max-width:24rem;">
        <label>@Loc["Login.Email"]
            <InputText @bind-Value="Input.Email" autocomplete="username" />
        </label>
        <label>@Loc["Login.Password"]
            <InputText type="password" @bind-Value="Input.Password" autocomplete="current-password" />
        </label>
        <label style="flex-direction:row; align-items:center; gap:.4rem;">
            <InputCheckbox @bind-Value="Input.RememberMe" style="width:auto;" />
            @Loc["Login.RememberMe"]
        </label>
        <ValidationSummary />
        <button type="submit">@Loc["Login.Submit"]</button>
    </div>
</EditForm>

<p><a href="/account/forgot-password">@Loc["Reset.Forgot.Link"]</a></p>
<p>@Loc["Login.NoAccount"] <a href="/account/register">@Loc["Login.RegisterLink"]</a> @Loc["Login.FirstAdminHint"]</p>

@code {
    // No initializer on a [SupplyParameterFromForm] property (BL0008: a form post could overwrite it with
    // null); default it in OnInitialized so a GET render still has a model to bind.
    [SupplyParameterFromForm] private InputModel Input { get; set; } = default!;
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }

    private string? errorMessage;
    private string? infoMessage;

    protected override void OnInitialized() => Input ??= new();

    private async Task LoginUser()
    {
        // Persistence is opt-in ("remember me" ships unchecked): a persistent cookie outlives the browser
        // session, so on a shared/kiosk device the next person would inherit this vault session.
        var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: true);
        if (result.Succeeded)
        {
            Nav.NavigateTo(string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl);
            return;
        }

        if (result.IsLockedOut)
        {
            errorMessage = Loc["Login.LockedOut"];
            return;
        }

        // IsNotAllowed means a known reason blocks sign-in — for us, an unconfirmed e-mail
        // (RequireConfirmedAccount). Re-send the confirmation link, but ONLY when the password is also correct,
        // so this can neither enumerate addresses nor spam arbitrary inboxes (auth policy). A wrong password
        // falls through to the same generic "invalid" message, revealing nothing.
        if (result.IsNotAllowed && await TryResendConfirmationAsync())
        {
            infoMessage = Loc["Login.Unconfirmed.Resent"];
            return;
        }

        errorMessage = Loc["Login.Invalid"];
    }

    private async Task<bool> TryResendConfirmationAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null
            || await UserManager.IsEmailConfirmedAsync(user)
            || !await UserManager.CheckPasswordAsync(user, Input.Password))
        {
            return false;
        }

        var token = await UserManager.GenerateEmailConfirmationTokenAsync(user);
        var encoded = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(token));
        var link = Nav.GetUriWithQueryParameters(
            Nav.ToAbsoluteUri("account/confirm-email").AbsoluteUri,
            new Dictionary<string, object?> { ["userId"] = user.Id, ["token"] = encoded });

        try
        {
            await EmailSender.SendEmailConfirmationLinkAsync(user.Email!, link);
        }
        catch (Exception ex)
        {
            // A transient delivery failure must not break sign-in; the user can retry. Still show the same
            // message (the operator sees the delivery error in the logs).
            Logger.LogError(ex, "Failed to re-send the confirmation e-mail to {Email}.", user.Email);
        }

        return true;
    }

    private sealed class InputModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";

        [Required, DataType(DataType.Password)]
        public string Password { get; set; } = "";

        public bool RememberMe { get; set; }
    }
}
