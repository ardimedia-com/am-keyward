@page "/account/forgot-password"
@using System.ComponentModel.DataAnnotations
@using System.Text
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using Am.Keyward.Ui.Blazor.App.Identity
@inject UserManager<IdentityUser> UserManager
@inject IAccountEmailSender EmailSender
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@KeywardOptions.ProductName</PageTitle>

<h1>@Loc["Reset.Forgot.Title"]</h1>
<p>@Loc["Reset.Forgot.Desc"]</p>

@if (submitted)
{
    <div class="notice" role="status">@Loc["Reset.Forgot.Sent"]</div>
}
else
{
    <EditForm Model="Input" method="post" OnValidSubmit="SendAsync" FormName="forgot">
        <DataAnnotationsValidator />
        <div style="display:flex; flex-direction:column; gap:.5rem; max-width:24rem;">
            <label>@Loc["Login.Email"]
                <InputText @bind-Value="Input.Email" autocomplete="username" />
            </label>
            <ValidationSummary />
            <button type="submit">@Loc["Reset.Forgot.Submit"]</button>
        </div>
    </EditForm>
}

<p><a href="account/login">@Loc["Register.SignInLink"]</a></p>

@code {
    [SupplyParameterFromForm] private InputModel Input { get; set; } = default!;

    private bool submitted;

    protected override void OnInitialized() => Input ??= new();

    private async Task SendAsync()
    {
        // Always show the same confirmation (no account enumeration): only actually send if the account exists.
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is not null)
        {
            var token = await UserManager.GeneratePasswordResetTokenAsync(user);
            var encoded = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(token));
            var link = Nav.GetUriWithQueryParameters(
                Nav.ToAbsoluteUri("account/reset-password").AbsoluteUri,
                new Dictionary<string, object?> { ["email"] = Input.Email, ["token"] = encoded });
            await EmailSender.SendPasswordResetLinkAsync(Input.Email, link);
        }

        submitted = true;
    }

    private sealed class InputModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";
    }
}
