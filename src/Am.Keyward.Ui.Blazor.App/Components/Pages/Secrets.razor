@page "/secrets"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@using Am.Keyward.Core.Application
@using Am.Keyward.Core.Domain.ValueObjects
@using Am.Keyward.Ui.Blazor.App
@using Am.Keyward.Ui.Blazor.App.Identity
@using Microsoft.AspNetCore.Components.Authorization
@inject ISoftwareSecretService SecretService
@inject AuthenticationStateProvider AuthState
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>AM KEYWARD</PageTitle>

<div class="page-header">
    <h1>@Loc["Page.Secrets.Title"]</h1>
    <p>@Loc["Page.Secrets.Desc"]</p>
</div>

@if (status is not null)
{
    <div class="notice @(status.Value.IsError ? "notice-error" : "")">@status.Value.Text</div>
}

<div class="card">
    <div class="row" style="justify-content:space-between;">
        <h3 style="margin:0;">Secrets</h3>
        <button class="btn-sm" @onclick="StartAdd" disabled="@busy">Add secret</button>
    </div>
    <p class="muted">A secret is a key (e.g. <code>ConnectionStrings:Main</code>) that can hold a different value in each environment. Choose <em>View</em> to see or change its values, or <em>Delete…</em> to open it and remove it.</p>

    @if (mode == "view" && detail is not null)
    {
        <div class="panel">
            <div class="row" style="justify-content:space-between;">
                <h4 style="margin:0;"><code>@detail.Key</code></h4>
                <div class="row">
                    <button class="btn-ghost btn-sm" @onclick="() => reveal = !reveal">@(reveal ? "Hide values" : "Reveal values")</button>
                    <button class="btn-danger btn-sm" @onclick="DeleteCurrentAsync" disabled="@busy">Delete</button>
                    <button class="btn-ghost btn-sm" @onclick="BackToList">Close</button>
                </div>
            </div>
            <p class="muted">Set or change the value per environment. Each save creates a new encrypted version.</p>
            <table>
                <thead><tr><th>Environment</th><th>Current value</th><th>Set new value</th></tr></thead>
                <tbody>
                    @foreach (var env in detail.Environments)
                    {
                        <tr>
                            <td>@env.Environment</td>
                            <td><code>@(env.HasValue ? (reveal ? env.Value : "••••••••") : "—")</code></td>
                            <td class="row">
                                <input @bind="editValues[env.Environment]" placeholder="new value" style="max-width:18rem;" />
                                <button class="btn-sm" @onclick="() => SetValueAsync(env.Environment)" disabled="@(busy || string.IsNullOrEmpty(editValues[env.Environment]))">Save</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (mode == "add")
    {
        <div class="panel">
            <h4 style="margin-top:0;">Add secret</h4>
            <div class="stack" style="max-width:32rem;">
                <div class="field"><label>Key</label><input @bind="addKey" placeholder="ConnectionStrings:Main" /></div>
                <div class="field">
                    <label>Environment</label>
                    <select @bind="addEnv">
                        @foreach (var e in EnvironmentName.DefaultSet)
                        {
                            <option value="@e.Value">@e.Value</option>
                        }
                    </select>
                </div>
                <div class="field"><label>Value</label><input @bind="addValue" /></div>
                <div class="row">
                    <button @onclick="SaveNewAsync" disabled="@(busy || string.IsNullOrWhiteSpace(addKey))">Save</button>
                    <button class="btn-ghost" @onclick="BackToList">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (secrets is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (secrets.Count == 0)
    {
        <p class="muted">No secrets yet — use “Add secret”.</p>
    }
    else
    {
        @if (secrets.Count > 5)
        {
            <input @bind="filter" @bind:event="oninput" placeholder="Filter secrets…" style="max-width:18rem; margin-bottom:.5rem;" />
        }
        <table>
            <thead><tr><th>Key</th><th>Environments with a value</th><th></th></tr></thead>
            <tbody>
                @foreach (var s in Filtered)
                {
                    <tr>
                        <td><code>@s.Key</code></td>
                        <td>
                            @if (s.EnvironmentsWithValue.Count == 0)
                            {
                                <span class="muted">none</span>
                            }
                            else
                            {
                                @foreach (var e in s.EnvironmentsWithValue)
                                {
                                    <span class="badge" style="margin-right:.25rem;">@e</span>
                                }
                            }
                        </td>
                        <td class="row-actions">
                            <button class="btn-ghost btn-sm" @onclick="() => ViewAsync(s.Key)" disabled="@busy">View</button>
                            <button class="btn-ghost btn-sm" @onclick="() => ViewAsync(s.Key)" disabled="@busy">Delete…</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private Guid? actorUserId;
    private IReadOnlyList<SoftwareSecretSummary>? secrets;
    private string mode = "list";
    private SoftwareSecretDetail? detail;
    private bool reveal;
    private string filter = "";

    private string addKey = "";
    private string addEnv = "Development";
    private string addValue = "";

    private readonly Dictionary<string, string> editValues = new();

    private (string Text, bool IsError)? status;
    private bool busy;

    private IEnumerable<SoftwareSecretSummary> Filtered =>
        secrets is null ? []
        : string.IsNullOrWhiteSpace(filter) ? secrets
        : secrets.Where(s => s.Key.Contains(filter.Trim(), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (Guid.TryParse(state.User.FindFirst(KeywardUserClaimsPrincipalFactory.UserIdClaim)?.Value, out var id))
        {
            actorUserId = id;
        }

        await ReloadAsync();
    }

    private async Task ReloadAsync() =>
        secrets = await SecretService.ListSecretsAsync(Demo.TenantId, Demo.ProjectId);

    private void StartAdd()
    {
        mode = "add";
        addKey = ""; addEnv = "Development"; addValue = "";
    }

    private Task ViewAsync(string key) => RunAsync(async () =>
    {
        detail = await SecretService.GetSecretAsync(Demo.TenantId, Demo.ProjectId, key);
        reveal = false;
        editValues.Clear();
        if (detail is not null)
        {
            foreach (var e in detail.Environments)
            {
                editValues[e.Environment] = "";
            }
        }
        mode = "view";
    }, true);

    private Task SetValueAsync(string environment) => RunAsync(async () =>
    {
        await SecretService.StoreAsync(new StoreSoftwareSecretCommand(Demo.TenantId, Demo.ProjectId, environment, detail!.Key, editValues[environment], actorUserId));
        await ViewAsync(detail!.Key);
        await ReloadAsync();
        status = ($"Saved {detail!.Key} in {environment}.", false);
    }, detail is not null && !string.IsNullOrEmpty(editValues.GetValueOrDefault(environment)));

    private Task SaveNewAsync() => RunAsync(async () =>
    {
        await SecretService.StoreAsync(new StoreSoftwareSecretCommand(Demo.TenantId, Demo.ProjectId, addEnv, addKey, addValue, actorUserId));
        var key = addKey;
        await ReloadAsync();
        await ViewAsync(key);
        status = ($"Secret {key} created.", false);
    }, !string.IsNullOrWhiteSpace(addKey));

    private Task DeleteCurrentAsync() => RunAsync(async () =>
    {
        await SecretService.DeleteSecretAsync(Demo.TenantId, Demo.ProjectId, detail!.Key, actorUserId);
        await ReloadAsync();
        BackToList();
        status = ("Secret deleted.", false);
    }, detail is not null);

    private void BackToList()
    {
        mode = "list";
        detail = null;
        reveal = false;
    }

    private async Task RunAsync(Func<Task> action, bool precondition)
    {
        if (busy || !precondition) return;
        busy = true;
        status = null;
        try { await action(); }
        catch (Exception ex) { status = ("Error: " + ex.Message, true); }
        finally { busy = false; }
    }
}
