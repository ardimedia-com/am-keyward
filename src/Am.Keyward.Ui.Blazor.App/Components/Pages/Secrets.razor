@page "/secrets"
@rendermode InteractiveServer
@attribute [Authorize]
@using Am.Keyward.Core.Application
@using Am.Keyward.Ui.Blazor.App
@inject ISoftwareSecretService SecretService

<PageTitle>Software credentials</PageTitle>

<h1>Software credentials (demo)</h1>
<p>Demo project; values are envelope-encrypted in SQL Server, scoped per environment.</p>

<div style="display:flex; flex-direction:column; gap:.5rem; max-width:40rem;">
    <label>Environment
        <select @bind="environment">
            <option>Development</option>
            <option>Test</option>
            <option>Preview</option>
            <option>Production</option>
        </select>
    </label>
    <label>Key <input @bind="key" placeholder="ConnectionStrings:Main" /></label>
    <label>Value <input @bind="value" /></label>
    <div style="display:flex; gap:.5rem;">
        <button @onclick="StoreAsync" disabled="@busy">Store</button>
        <button @onclick="ReadAsync" disabled="@busy">Read</button>
    </div>
</div>

@if (status is not null)
{
    <p><strong>@status</strong></p>
}
@if (readValue is not null)
{
    <p>Read value: <code>@readValue</code></p>
}

@code {
    private string environment = "Production";
    private string key = "ConnectionStrings:Main";
    private string value = "";
    private string? status;
    private string? readValue;
    private bool busy;

    private async Task StoreAsync()
    {
        if (busy || string.IsNullOrWhiteSpace(key))
        {
            return;
        }

        busy = true;
        status = null;
        try
        {
            await SecretService.StoreAsync(new StoreSoftwareSecretCommand(Demo.TenantId, Demo.ProjectId, environment, key, value, null));
            status = $"Stored '{key}' in {environment}.";
        }
        catch (Exception ex)
        {
            status = "Error: " + ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ReadAsync()
    {
        if (busy || string.IsNullOrWhiteSpace(key))
        {
            return;
        }

        busy = true;
        status = null;
        readValue = null;
        try
        {
            var result = await SecretService.ReadAsync(new ReadSoftwareSecretQuery(Demo.TenantId, Demo.ProjectId, environment, key, null));
            readValue = result ?? "(not found)";
        }
        catch (Exception ex)
        {
            status = "Error: " + ex.Message;
        }
        finally
        {
            busy = false;
        }
    }
}
