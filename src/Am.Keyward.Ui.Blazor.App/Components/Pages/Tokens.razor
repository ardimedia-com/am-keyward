@page "/tokens"
@* Prerender disabled: loads tenant-scoped data in OnInitializedAsync, set by the circuit handler. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@using Am.Keyward.Core.Application
@using Am.Keyward.Ui.Blazor.App
@using Am.Keyward.Ui.Blazor.App.Identity
@using Microsoft.AspNetCore.Components.Authorization
@inject ISoftwareClientTokenService TokenService
@inject AuthenticationStateProvider AuthState
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>AM KEYWARD</PageTitle>

<div class="page-header">
    <h1>@Loc["Page.Tokens.Title"]</h1>
    <p>@Loc["Page.Tokens.Desc"]</p>
</div>

@if (status is not null)
{
    <div class="notice @(status.StartsWith("Error", StringComparison.Ordinal) ? "notice-error" : "")">@status</div>
}
@if (issuedToken is not null)
{
    <div class="notice notice-reveal">
        New token (copy it now — it will not be shown again):<br />
        <code>@issuedToken</code>
    </div>
}

<div class="card">
    <h3>Issue a token</h3>
    <p class="muted">Scope a token to one environment so a leaked token cannot read another. Add a note (e.g. where it is deployed) and an optional expiry.</p>
    <div class="stack" style="max-width:32rem; margin-top:.5rem;">
        <div class="field">
            <label>Environment</label>
            <select @bind="environment">
                <option>Development</option>
                <option>Test</option>
                <option>Preview</option>
                <option>Production</option>
            </select>
        </div>
        <div class="field"><label>Name</label><input @bind="name" placeholder="orders-service prod" /></div>
        <div class="field"><label>Note (optional)</label><textarea rows="2" @bind="note" placeholder="where it's used, owner, ticket…"></textarea></div>
        <div class="field"><label>Expires in (days, optional)</label><input type="number" min="1" @bind="expiresInDays" style="max-width:10rem;" /></div>
        <div class="row"><button @onclick="IssueAsync" disabled="@(busy || string.IsNullOrWhiteSpace(name))">Issue token</button></div>
    </div>
</div>

<div class="card">
    <h3>Existing tokens</h3>
    <p class="muted">Edit a token's name/note any time. Rotate replaces its secret (the old one stops working); Revoke disables it.</p>

    @if (editingTokenId is not null)
    {
        <div class="panel">
            <h4 style="margin-top:0;">Edit token</h4>
            <div class="stack" style="max-width:32rem;">
                <div class="field"><label>Name</label><input @bind="editName" /></div>
                <div class="field"><label>Note</label><textarea rows="2" @bind="editNote"></textarea></div>
                <div class="row">
                    <button @onclick="SaveEditAsync" disabled="@(busy || string.IsNullOrWhiteSpace(editName))">Save</button>
                    <button class="btn-ghost" @onclick="() => editingTokenId = null">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (list is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (list.Count == 0)
    {
        <p class="muted">No tokens yet — issue one above.</p>
    }
    else
    {
        @if (list.Count > 5)
        {
            <input @bind="tokenFilter" @bind:event="oninput" placeholder="Filter tokens…" style="max-width:18rem; margin-bottom:.5rem;" />
        }
        <table>
            <thead>
                <tr><th>Name</th><th>Note</th><th>Prefix</th><th>Created</th><th>Expires</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var token in FilteredTokens)
                {
                    <tr>
                        <td>@token.Name</td>
                        <td class="muted">@(string.IsNullOrWhiteSpace(token.Note) ? "—" : token.Note)</td>
                        <td><code>@token.TokenPrefix</code></td>
                        <td>@token.CreatedAt.UtcDateTime.ToString("u")</td>
                        <td>@(token.ExpiresAt?.UtcDateTime.ToString("u") ?? "—")</td>
                        <td><span class="badge @StatusBadge(token)">@StatusOf(token)</span></td>
                        <td class="row-actions">
                            <button class="btn-ghost btn-sm" @onclick="() => StartEdit(token)" disabled="@busy">Edit</button>
                            @if (token.RevokedAt is null)
                            {
                                <button class="btn-ghost btn-sm" @onclick="() => RotateAsync(token.Id)" disabled="@busy">Rotate</button>
                                <button class="btn-danger btn-sm" @onclick="() => RevokeAsync(token.Id)" disabled="@busy">Revoke</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private string environment = "Production";
    private string name = "";
    private string note = "";
    private int? expiresInDays;
    private string? status;
    private string? issuedToken;
    private bool busy;
    private Guid? actorUserId;
    private IReadOnlyList<SoftwareClientTokenInfo>? list;
    private string tokenFilter = "";

    private Guid? editingTokenId;
    private string editName = "";
    private string editNote = "";

    private IEnumerable<SoftwareClientTokenInfo> FilteredTokens =>
        list is null ? []
        : string.IsNullOrWhiteSpace(tokenFilter) ? list
        : list.Where(t => $"{t.Name} {t.Note} {t.TokenPrefix}".Contains(tokenFilter.Trim(), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        if (Guid.TryParse(authState.User.FindFirst(KeywardUserClaimsPrincipalFactory.UserIdClaim)?.Value, out var id))
        {
            actorUserId = id;
        }

        await RefreshAsync();
    }

    private async Task RefreshAsync() => list = await TokenService.ListAsync(Demo.TenantId, Demo.ProjectId);

    private async Task IssueAsync()
    {
        if (busy || string.IsNullOrWhiteSpace(name)) return;
        busy = true; status = null; issuedToken = null;
        try
        {
            var expiresAt = expiresInDays is > 0 ? DateTimeOffset.UtcNow.AddDays(expiresInDays.Value) : (DateTimeOffset?)null;
            var issued = await TokenService.IssueAsync(
                new IssueSoftwareClientTokenCommand(Demo.TenantId, Demo.ProjectId, environment, name, expiresAt, actorUserId, note));
            issuedToken = issued.Token;
            status = $"Issued token '{name}' for {environment}.";
            name = ""; note = "";
            await RefreshAsync();
        }
        catch (Exception ex) { status = "Error: " + ex.Message; }
        finally { busy = false; }
    }

    private void StartEdit(SoftwareClientTokenInfo token)
    {
        editingTokenId = token.Id;
        editName = token.Name;
        editNote = token.Note;
    }

    private async Task SaveEditAsync()
    {
        if (busy || editingTokenId is null || string.IsNullOrWhiteSpace(editName)) return;
        busy = true; status = null;
        try
        {
            await TokenService.UpdateAsync(Demo.TenantId, editingTokenId.Value, editName, editNote, actorUserId);
            editingTokenId = null;
            await RefreshAsync();
            status = "Token updated.";
        }
        catch (Exception ex) { status = "Error: " + ex.Message; }
        finally { busy = false; }
    }

    private async Task RotateAsync(Guid tokenId)
    {
        if (busy) return;
        busy = true; status = null; issuedToken = null;
        try
        {
            var rotated = await TokenService.RotateAsync(Demo.TenantId, tokenId, null, actorUserId);
            issuedToken = rotated.Token;
            status = "Rotated — the previous token has stopped working.";
            await RefreshAsync();
        }
        catch (Exception ex) { status = "Error: " + ex.Message; }
        finally { busy = false; }
    }

    private async Task RevokeAsync(Guid tokenId)
    {
        if (busy) return;
        busy = true; status = null;
        try
        {
            await TokenService.RevokeAsync(Demo.TenantId, tokenId, actorUserId);
            status = "Token revoked.";
            await RefreshAsync();
        }
        catch (Exception ex) { status = "Error: " + ex.Message; }
        finally { busy = false; }
    }

    private static string StatusOf(SoftwareClientTokenInfo token) =>
        token.RevokedAt is not null ? "Revoked" : token.IsActive ? "Active" : "Expired";

    private static string StatusBadge(SoftwareClientTokenInfo token) =>
        token.RevokedAt is not null ? "badge-danger" : token.IsActive ? "badge-success" : "badge-warning";
}
