@page "/"
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@KeywardOptions.ProductName</PageTitle>

<div class="page-header">
    <h1>@KeywardOptions.ProductName</h1>
    <p>@Loc["Home.Tagline"]</p>
</div>

<AuthorizeView>
    <Authorized>
        @* Two groups mirroring the sidebar: vaults are for people, software credentials for applications.
           Each tile explains its section with concrete examples, so a first-time user knows where to go. *@
        <section class="home-group">
            <h2>@Loc["Nav.Group.Vaults"]</h2>
            <p class="muted">@Loc["Home.Group.Vaults.Desc"]</p>
            <div class="tile-grid tile-grid-2">
                <a class="tile tile-rich" href="@KeywardRoutes.PersonalVaults">
                    <KeywardIcon Name="lock" Size="22" />
                    <span>
                        <span class="tile-title">@Loc["Nav.PersonalVaults"]</span>
                        <span class="tile-desc">@Loc["Home.Tile.Personal"]</span>
                    </span>
                </a>
                <a class="tile tile-rich" href="@KeywardRoutes.TeamVaults">
                    <KeywardIcon Name="users" Size="22" />
                    <span>
                        <span class="tile-title">@Loc["Nav.TeamVaults"]</span>
                        <span class="tile-desc">@Loc["Home.Tile.Team"]</span>
                    </span>
                </a>
            </div>
        </section>

        <section class="home-group">
            <h2>@Loc["Nav.Group.Software"]</h2>
            <p class="muted">@Loc["Home.Group.Software.Desc"]</p>
            <div class="tile-grid tile-grid-2">
                <a class="tile tile-rich" href="@KeywardRoutes.Applications">
                    <KeywardIcon Name="package" Size="22" />
                    <span>
                        <span class="tile-title">@Loc["Nav.Applications"]</span>
                        <span class="tile-desc">@Loc["Home.Tile.Apps"]</span>
                    </span>
                </a>
                @* Application data (secrets) and client tokens are tabs inside the Applications page now. *@
            </div>
        </section>
    </Authorized>
    <NotAuthorized>
        <div class="card">
            <p>@Loc["Home.SignInPrompt"]</p>
            <div class="row" style="margin-top:.5rem;">
                <a class="btn" href="account/login">@Loc["Nav.SignIn"]</a>
                <a class="btn btn-ghost" href="account/register">@Loc["Home.Register"]</a>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
