@inject IStringLocalizer<SharedResource> Loc

<div class="nav-brand">
    <a href="">
        <svg width="22" height="22" viewBox="0 0 64 64" aria-hidden="true" style="vertical-align:-4px; margin-right:.4rem;">
            <rect width="64" height="64" rx="14" fill="#4f46e5" />
            <path fill="#ffffff" fill-rule="evenodd" d="M32 12a12 12 0 110 24 12 12 0 010-24zm0 6a6 6 0 100 12 6 6 0 000-12z" />
            <g fill="#ffffff">
                <rect x="29" y="33" width="6" height="19" rx="2" />
                <rect x="35" y="38" width="8" height="4.5" rx="1.5" />
                <rect x="35" y="46" width="5.5" height="4.5" rx="1.5" />
            </g>
        </svg>@KeywardOptions.ProductName
    </a>
</div>

<nav class="nav-links">
    <NavLink class="nav-link" href="" Match="NavLinkMatch.All"><KeywardIcon Name="house" /><span>@Loc["Nav.Home"]</span></NavLink>
    @* The Keyward section links (grouped, with icons) come from the RCL so routes aren't hardcoded here. *@
    <KeywardNav />
    @* Administration — shell-specific composition, so it lives here, not in the RCL. Groups are visible
       to every signed-in user (group admins manage their members there); the user administration stays
       system-admin-only. *@
    <AuthorizeView>
        <div class="nav-group-label">@Loc["Nav.Group.Admin"]</div>
    </AuthorizeView>
    <AuthorizeView Policy="Keyward.SystemAdmin">
        <NavLink class="nav-link" href="account/admin/users"><KeywardIcon Name="shield" /><span>@Loc["Nav.AdminUsers"]</span></NavLink>
    </AuthorizeView>
    <AuthorizeView>
        <NavLink class="nav-link" href="@KeywardRoutes.Groups"><KeywardIcon Name="users-round" /><span>@Loc["Nav.Groups"]</span></NavLink>
        <NavLink class="nav-link" href="@KeywardRoutes.DefaultEnvironments"><KeywardIcon Name="layers" /><span>@Loc["Nav.DefaultEnvs"]</span></NavLink>
    </AuthorizeView>
</nav>
